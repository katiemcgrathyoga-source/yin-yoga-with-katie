---
import '../styles/global.css';
import { SITE } from '../data/site';

/**
 * The site-wide document shell. Owns the <head>: fonts, SEO title/description,
 * Open Graph + Twitter tags, canonical URL, and an optional JSON-LD block.
 * Every page renders inside this so SEO is consistent and defined in one place.
 */
interface Props {
  title: string;
  description: string;
  /** Open Graph overrides; fall back to title/description when omitted. */
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  /** Absolute or root-relative image URL for OG/Twitter cards. */
  image?: string;
  /** A pre-serialised JSON-LD object rendered as <script type="application/ld+json">. */
  jsonLd?: unknown;
  /** When true, emit <meta name="robots" content="noindex"> (thin/skeleton pages). */
  noindex?: boolean;
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  image,
  jsonLd,
  noindex = false,
} = Astro.props;

// Canonical + absolute OG image, resolved against `site` in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;

// Simple top nav, shared across every page. `aria-current` marks the section
// the current path falls under so the active link is highlighted.
const path = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Library', match: (p: string) => p === '/' || p.startsWith('/videos') },
  { href: '/poses', label: 'Poses', match: (p: string) => p.startsWith('/poses') },
  { href: '/routines', label: 'Routines', match: (p: string) => p.startsWith('/routines') },
  { href: '/programs', label: 'Programs', match: (p: string) => p.startsWith('/programs') },
  { href: '/calendar', label: 'Calendar', match: (p: string) => p.startsWith('/calendar') },
  { href: '/blog', label: 'Journal', match: (p: string) => p.startsWith('/blog') },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/brand/submark-deep-sage.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@200..900&family=Cabin:ital,wght@0,400..700;1,400..700&display=swap"
      rel="stylesheet"
    />

    {
      jsonLd && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
  </head>
  <body>
    <header class="topbar">
      <div class="bar">
        <a class="brand" href="/" aria-label="Yin Yoga with Katie — home">
          <img src="/brand/wordmark-deep-sage.png" alt="Yin Yoga with Katie" class="brand-logo" width="176" height="30" />
        </a>
        <button class="nav-toggle" id="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="primary-nav">
          <span class="nav-toggle-bars" aria-hidden="true"></span>
        </button>
        <nav class="nav" id="primary-nav" aria-label="Primary">
          {
            nav.map((item) => (
              <a href={item.href} aria-current={item.match(path) ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <script>
      const t = document.getElementById('nav-toggle');
      const n = document.getElementById('primary-nav');
      if (t && n) {
        const close = () => { n.classList.remove('open'); t.setAttribute('aria-expanded', 'false'); };
        t.addEventListener('click', () => {
          const open = n.classList.toggle('open');
          t.setAttribute('aria-expanded', String(open));
        });
        n.addEventListener('click', (e) => { if ((e.target as HTMLElement).tagName === 'A') close(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      }
    </script>
    <slot />
    <footer class="site-footer">
      <img src="/brand/submark-deep-sage.png" alt="Yin Yoga with Katie" class="site-footer-logo" width="125" height="104" loading="lazy" />
      <p class="site-footer-tag">a calmer, more flexible you — one long, slow practice at a time</p>
      <nav class="site-footer-nav" aria-label="Footer">
        <a href="/">Library</a>
        <a href="/poses">Poses</a>
        <a href="/routines">Routines</a>
        <a href="/programs">Programs</a>
        <a href="/calendar">Calendar</a>
        <a href="/blog">Journal</a>
        <a href="/free-class">Free class</a>
      </nav>
      <nav class="site-footer-social" aria-label="Katie on social media">
        {SITE.socials.substack && (
          <a href={SITE.socials.substack} target="_blank" rel="noopener" aria-label="Read Katie on Substack" title="Substack">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
          </a>
        )}
        {SITE.socials.instagram && (
          <a href={SITE.socials.instagram} target="_blank" rel="noopener" aria-label="Katie on Instagram" title="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true"><rect x="2.5" y="2.5" width="19" height="19" rx="5.4"/><circle cx="12" cy="12" r="4.4"/><circle cx="17.6" cy="6.4" r="1.15" fill="currentColor" stroke="none"/></svg>
          </a>
        )}
        {SITE.socials.tiktok && (
          <a href={SITE.socials.tiktok} target="_blank" rel="noopener" aria-label="Katie on TikTok" title="TikTok">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M16.6 5.82a4.28 4.28 0 0 1-1.06-2.82h-3.2v12.9a2.6 2.6 0 1 1-2.6-2.6c.27 0 .53.04.78.12v-3.3a5.9 5.9 0 0 0-.78-.05 5.9 5.9 0 1 0 5.9 5.9V9.4a7.5 7.5 0 0 0 4.36 1.4V7.6a4.28 4.28 0 0 1-3.4-1.78z"/></svg>
          </a>
        )}
        {SITE.socials.pinterest && (
          <a href={SITE.socials.pinterest} target="_blank" rel="noopener" aria-label="Katie on Pinterest" title="Pinterest">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.64 7.86 6.36 9.32-.09-.79-.17-2 .03-2.87.18-.76 1.18-4.82 1.18-4.82s-.3-.6-.3-1.5c0-1.4.82-2.45 1.83-2.45.86 0 1.28.65 1.28 1.42 0 .87-.55 2.17-.84 3.37-.24 1.01.5 1.83 1.5 1.83 1.8 0 3.18-1.9 3.18-4.64 0-2.42-1.74-4.12-4.23-4.12-2.88 0-4.57 2.16-4.57 4.4 0 .87.33 1.8.75 2.31.08.1.1.19.07.3l-.28 1.15c-.04.18-.15.22-.34.13-1.26-.59-2.05-2.42-2.05-3.9 0-3.18 2.31-6.1 6.66-6.1 3.5 0 6.22 2.49 6.22 5.82 0 3.47-2.19 6.27-5.23 6.27-1.02 0-1.98-.53-2.31-1.16l-.63 2.4c-.23.88-.85 1.98-1.26 2.65.95.29 1.95.45 3 .45 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
          </a>
        )}
        {SITE.socials.youtube && (
          <a href={SITE.socials.youtube} target="_blank" rel="noopener" aria-label="Katie on YouTube" title="YouTube">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.11-2.12C19.5 3.56 12 3.56 12 3.56s-7.5 0-9.39.52A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.11 2.12c1.89.52 9.39.52 9.39.52s7.5 0 9.39-.52a3 3 0 0 0 2.11-2.12A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8zM9.6 15.57V8.43L15.8 12l-6.2 3.57z"/></svg>
          </a>
        )}
      </nav>
      {
        SITE.coffeeUrl && (
          <a class="footer-coffee" href={SITE.coffeeUrl} target="_blank" rel="noopener">
            ☕ Buy me a coffee
          </a>
        )
      }
      <p class="site-footer-copy">© Yin Yoga with Katie</p>
    </footer>
  </body>
</html>
