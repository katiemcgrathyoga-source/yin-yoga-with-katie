---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { journalPinVariants, type JournalVariant } from '../lib/journalPin';

// Katie's private pinning console (noindex, unlisted). Shows BOTH the original
// hand-curated pins (the /pin/card.png template set) AND the newer four-variant
// Journal Pins (/pin/journal.png) — the new designs are added alongside the old,
// not replacing them. Routines are the exception: their pins move fully to the
// new Journal Pin (the old numbered-sequence routine pin is retired).
const site = Astro.site!;
const enc = encodeURIComponent;
const JOURNAL_VARIANTS: JournalVariant[] = ['arch', 'oat-frame', 'split', 'card'];
const realPhoto = (p?: string) => (p && !p.includes('pose-placeholder') ? p : null);

type Pin = { label: string; isNew: boolean; img: string; save: string; clip: string };

// One Pinterest "Save" + copy-for-scheduler payload for a given rendered image.
function pinActions(img: string, title: string, description: string, pageUrl: string) {
  const save = `https://www.pinterest.com/pin/create/button/?url=${enc(pageUrl)}&media=${enc(img)}&description=${enc(description)}`;
  const clip = `${title}\n\n${description}\n\nImage: ${img}\nLink: ${pageUrl}`;
  return { save, clip };
}

// The four new Journal Pin variants for one item.
function journalPins(o: {
  title: string;
  description: string;
  pageUrl: string;
  eyebrow: string;
  meta?: string;
  excerpt?: string;
  photo?: string | null;
}): Pin[] {
  const variants = journalPinVariants(site, {
    title: o.title,
    eyebrow: o.eyebrow,
    meta: o.meta,
    excerpt: o.excerpt,
    photo: o.photo,
  });
  return JOURNAL_VARIANTS.map((variant) => ({
    label: variant,
    isNew: true,
    img: variants[variant],
    ...pinActions(variants[variant], o.title, o.description, o.pageUrl),
  }));
}

// --- Original curated pins (the /pin/card.png template set) -------------------
type Item = Record<string, string>;
type OldPin = { tpl: string; title: string; board: string; eyebrow?: string; img?: string; quote?: string; footer?: string; items?: Item[] };
type Plan = { description: string; pins: OldPin[] };

const PLAN: Record<string, Plan> = {
  'yin-yoga-for-sleep': {
    description:
      'How Yin Yoga helps you sleep — why the slow, long holds calm a busy mind, the best poses to do before bed, and short follow-along practices to help you drift off.',
    pins: [
      { tpl: 'band', img: '/poses/corpse.jpg', eyebrow: 'let the day go', title: 'Yin Yoga for Sleep: A Gentle Practice for Deeper Rest', board: 'Bedtime Yoga & Yin for Sleep' },
      { tpl: 'numbered', eyebrow: 'before bed', title: '6 Yin Yoga Poses for Better Sleep', board: 'Bedtime Yoga & Yin for Sleep',
        items: [{ name: 'Legs up the wall', note: '5 minutes', img: '/poses/legs-up-the-wall.jpg' }, { name: 'Butterfly', note: '3 minutes', img: '/poses/butterfly.jpg' }, { name: 'Caterpillar', note: '3 minutes', img: '/poses/caterpillar.jpg' }, { name: 'Banana', note: 'each side', img: '/poses/banana.jpg' }, { name: 'Savasana', note: 'until you drift off', img: '/poses/corpse.jpg' }] },
      { tpl: 'quote', eyebrow: 'from the journal', quote: 'You can’t force sleep — but you can make a soft place for it to find you.', title: 'You can’t force sleep', board: 'Yin Yoga Routines' },
    ],
  },
  'yin-yoga-for-beginners': {
    description:
      'New to Yin Yoga? What it is, how it’s different from other yoga, the three simple cues, and a gentle first practice you can do tonight — a calming beginner’s guide.',
    pins: [
      { tpl: 'photo', img: '/poses/camel.jpg', eyebrow: 'start tonight', title: 'Yin Yoga for Beginners: How to Start Tonight', board: 'Yin Yoga for Beginners' },
      { tpl: 'checklist', eyebrow: 'save this — start tonight', title: 'Everything a Yin Beginner Actually Needs', footer: 'the full beginner’s guide is on the blog', board: 'Yin Yoga for Beginners',
        items: [{ text: 'a folded blanket', aside: '(no mat needed)' }, { text: 'two pillows for support' }, { text: '15 unhurried minutes' }, { text: 'no flexibility whatsoever' }] },
      { tpl: 'numbered', eyebrow: 'to start with', title: '5 Gentle Yin Poses for Beginners', board: 'Yin Yoga Poses',
        items: [{ name: 'Caterpillar', note: '3 minutes', img: '/poses/caterpillar.jpg' }, { name: 'Swan', note: '3 min each side', img: '/poses/swan.jpg' }, { name: "Child's pose", note: '4 minutes', img: '/poses/childs-pose.jpg' }, { name: 'Banana', note: 'each side', img: '/poses/banana.jpg' }, { name: 'Savasana', note: 'to finish', img: '/poses/corpse.jpg' }] },
      { tpl: 'text', img: '/poses/caterpillar.jpg', eyebrow: 'begin gently', title: 'New to Yin? The 3 Simple Cues That Make It Work', board: 'Bedtime Yoga & Yin for Sleep' },
    ],
  },
  'bedtime-yin-yoga-3-night-wind-down': {
    description:
      'A gentle 3-night bedtime Yin Yoga wind-down — three 30-minute evening classes to help you slow down, quiet a racing mind and fall asleep more easily. No props required.',
    pins: [
      { tpl: 'band', img: '/poses/banana.jpg', eyebrow: 'three quiet evenings', title: 'Bedtime Yin Yoga: A Gentle 3-Night Wind-Down', board: 'Bedtime Yoga & Yin for Sleep' },
      { tpl: 'numbered', eyebrow: 'for deeper sleep', title: '5 Yin Poses to Do in Bed Tonight', board: 'Bedtime Yoga & Yin for Sleep',
        items: [{ name: 'Caterpillar', note: '3 minutes', img: '/poses/caterpillar.jpg' }, { name: "Child's pose", note: '4 minutes', img: '/poses/childs-pose.jpg' }, { name: 'Banana', note: 'each side', img: '/poses/banana.jpg' }, { name: 'Reclined swan', note: '3 min each side', img: '/poses/swan.jpg' }, { name: 'Savasana', note: 'until you drift off', img: '/poses/corpse.jpg' }] },
      { tpl: 'ritual', eyebrow: 'tonight, from nine', title: 'An Unhurried Hour Before Sleep', board: 'Yin Yoga Routines',
        items: [{ time: '9:00', text: 'lights low, phone away' }, { time: '9:10', text: 'butterfly, three quiet minutes' }, { time: '9:20', text: 'a slow twist, each side' }, { time: '9:35', text: 'legs up the wall' }, { time: '9:50', text: 'into bed, already resting' }] },
      { tpl: 'quote', eyebrow: 'from the journal', quote: 'You don’t have to earn your rest.', title: 'You don’t have to earn your rest', board: 'Bedtime Yoga & Yin for Sleep' },
    ],
  },
  'how-long-to-hold-yin-poses': {
    description:
      'How long to hold Yin Yoga poses, why the holds are so long, what’s right for beginners, and how to know when it’s time to ease out.',
    pins: [
      { tpl: 'text', img: '/poses/caterpillar.jpg', eyebrow: 'stay a while', title: 'How Long Should You Hold Yin Yoga Poses?', board: 'Yin Yoga Poses' },
      { tpl: 'photo', img: '/poses/swan.jpg', eyebrow: 'the simple answer', title: 'How Long to Hold Yin Yoga Poses (a Simple Guide)', board: 'Yin Yoga for Beginners' },
      { tpl: 'quote', eyebrow: 'on the mat', quote: 'Long enough to let go.', title: 'Long enough to let go', board: 'Yin Yoga for Flexibility' },
    ],
  },
  'a-new-home-for-yin': {
    description:
      'A calm, filterable home for every Yin Yoga class — with a pose library, guided programs, routines and a free two-hour retreat to begin.',
    pins: [{ tpl: 'text', img: '/poses/camel.jpg', eyebrow: 'a new home', title: 'A New Home for Yin — Free Classes, Poses & Routines', board: 'Yin Yoga Routines' }],
  },
};

function oldPinImage(pin: OldPin): string {
  const u = new URL('/pin/card.png', site);
  u.searchParams.set('tpl', pin.tpl);
  u.searchParams.set('t', pin.title);
  if (pin.eyebrow) u.searchParams.set('s', pin.eyebrow);
  if (pin.img) u.searchParams.set('img', pin.img);
  if (pin.quote) u.searchParams.set('q', pin.quote);
  if (pin.footer) u.searchParams.set('footer', pin.footer);
  if (pin.items) u.searchParams.set('items', JSON.stringify(pin.items));
  return u.href;
}

// --- Journal posts: original curated pins + the four new Journal Pins ---------
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const postCards = posts.map((post) => {
  const d = post.data;
  const plan = PLAN[d.slug] ?? { description: d.seo_description ?? d.description, pins: [{ tpl: 'text', title: d.title, board: 'Yin Yoga Routines' } as OldPin] };
  const postUrl = new URL(`/blog/${d.slug}/`, site).href;
  const oldPins: Pin[] = plan.pins.map((pin) => {
    const img = oldPinImage(pin);
    return { label: pin.tpl, isNew: false, img, ...pinActions(img, pin.title, plan.description, postUrl) };
  });
  const newPins = journalPins({
    title: d.title,
    description: d.seo_description ?? d.description,
    pageUrl: postUrl,
    eyebrow: 'From the journal',
    excerpt: d.description,
    photo: realPhoto(d.hero),
  });
  return { title: d.title, board: 'From the journal', pins: [...oldPins, ...newPins] };
});

// --- Poses: original band pin + the four new Journal Pins ---------------------
const poses = (await getCollection('poses'))
  .filter((p) => realPhoto(p.data.images?.[0]))
  .sort((a, b) => a.data.name_en.localeCompare(b.data.name_en));

const poseCards = poses.map((pose) => {
  const d = pose.data;
  const poseUrl = new URL(`/poses/${d.slug}/`, site).href;
  const photo = realPhoto(d.images[0]);
  const oldImg = oldPinImage({ tpl: 'band', title: d.name_en, eyebrow: 'a yin yoga pose', img: photo ?? undefined, board: 'Yin Yoga Poses' });
  const oldPins: Pin[] = [{ label: 'band', isNew: false, img: oldImg, ...pinActions(oldImg, d.name_en, d.seo_description, poseUrl) }];
  const newPins = journalPins({
    title: d.name_en,
    description: d.seo_description,
    pageUrl: poseUrl,
    eyebrow: 'Pose library',
    // Never reveal the hold time on a pin (handoff rule): "Long hold" + areas.
    meta: `Long hold · ${d.target_areas.slice(0, 2).join(' & ')}`,
    excerpt: d.benefits[0],
    photo,
  });
  return { title: d.name_en, board: 'Yin Yoga Poses', pins: [...oldPins, ...newPins] };
});

// --- Routines: the numbered pose-list pin (lead) + the four new Journal Pins --
const poseBy = new Map((await getCollection('poses')).map((p) => [p.data.slug, p.data]));
const routines = (await getCollection('routines')).sort((a, b) => a.data.minutes - b.data.minutes);
const humanise = (slug: string) => slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
const fmtHold = (secs: number, sides: number) => `${Math.max(1, Math.round(secs / 60))} min${sides === 2 ? ' each side' : ''}`;

// The original numbered "5 poses" sequence pin (/pin/card.png), now with the
// enlarged 200×144 real-photo thumbnails. The strongest routine creative for
// Pinterest — kept as the lead, with the four Journal Pins as extra creatives.
function numberedRoutinePin(r: (typeof routines)[number]): Pin {
  const d = r.data;
  const rUrl = new URL(`/routines/${d.slug}/`, site).href;
  const items = d.steps.slice(0, 5).map((s) => {
    const p = poseBy.get(s.pose);
    const photo = realPhoto(p?.images?.[0]);
    return { name: p?.name_en ?? humanise(s.pose), note: fmtHold(s.seconds, s.sides), ...(photo ? { img: photo } : {}) };
  });
  const u = new URL('/pin/card.png', site);
  u.searchParams.set('tpl', 'numbered');
  u.searchParams.set('t', d.title);
  u.searchParams.set('s', `${d.minutes}-minute yin routine`);
  u.searchParams.set('items', JSON.stringify(items));
  const img = u.href;
  return { label: 'numbered · sequence', isNew: false, img, ...pinActions(img, d.title, d.summary, rUrl) };
}

const routineCards = routines.map((r) => {
  const d = r.data;
  const heroPose = (d.hero_pose && poseBy.get(d.hero_pose)) || poseBy.get(d.steps[0]?.pose);
  const rUrl = new URL(`/routines/${d.slug}/`, site).href;
  const journalVariants = journalPins({
    title: d.title,
    description: d.summary,
    pageUrl: rUrl,
    eyebrow: 'Routines',
    meta: `${d.minutes} minutes · ${d.level.replace(/-/g, ' ')}`,
    excerpt: d.summary,
    photo: realPhoto(heroPose?.images?.[0]),
  });
  return { title: d.title, board: 'Yin Yoga Routines', pins: [numberedRoutinePin(r), ...journalVariants] };
});

const sections = [
  { heading: 'Journal', lead: 'Each post’s original curated pins plus the four new Journal Pin variants (arch · oat-frame · split · card) — pick whichever suits the board.', cards: postCards },
  { heading: 'Poses', lead: 'Every pose with a photo: the original band pin plus the four new variants. Board: Yin Yoga Poses.', cards: poseCards },
  { heading: 'Routines', lead: 'Lead with the numbered “sequence” pin — the pose photos are the draw (now enlarged to 200×144). The four Journal Pin variants are extra creatives to space out over time. Board: Yin Yoga Routines.', cards: routineCards },
];
---

<BaseLayout title="Pin console" description="Private pinning console" noindex={true}>
  <div class="wrap pins">
    <h1>Pin console</h1>
    <p class="pins-lead">
      Every journal post, pose and routine, rendered on-brand at 1000×1500. The original pins are still here;
      the <strong>new</strong>-tagged cards are the four Journal Pin variants, added alongside.
      <strong>Save now</strong> pins immediately; <strong>Copy</strong> grabs the image, title, description and
      link for Pinterest’s scheduler or Buffer. Pin 2–3 per item, spaced a day or two apart.
    </p>

    {sections.map((sec) => (
      <section class="pins-sec">
        <h2>{sec.heading}</h2>
        <p class="pins-lead">{sec.lead}</p>
        {sec.cards.map((card) => (
          <div class="pinrow">
            <div class="pinrow-head">
              <h3>{card.title}</h3>
              <p class="pinrow-board">Board: <strong>{card.board}</strong></p>
            </div>
            <div class="pins-grid">
              {card.pins.map((pin) => (
                <div class="pincard">
                  <a href={pin.save} target="_blank" rel="noopener noreferrer" class="pincard-img">
                    <img src={pin.img} alt={`${card.title} — ${pin.label} pin`} loading="lazy" width="200" height="300" />
                    <span class={`pincard-tpl${pin.isNew ? ' is-new' : ''}`}>{pin.isNew ? `new · ${pin.label}` : pin.label}</span>
                  </a>
                  <div class="pincard-actions">
                    <a class="pincard-save" href={pin.save} target="_blank" rel="noopener noreferrer">Save</a>
                    <button type="button" class="pincard-copy" data-clip={pin.clip}>Copy</button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </section>
    ))}
  </div>

  <style>
    .pins { padding: 40px 22px 90px; }
    .pins h1 { font-family: var(--display); color: var(--plum); font-size: 40px; margin: 0 0 10px; }
    .pins-lead { color: var(--ink-soft); max-width: 72ch; margin: 0; line-height: 1.6; }
    .pins-sec { margin-top: 48px; border-top: 1px solid var(--line); padding-top: 28px; }
    .pins-sec h2 { font-family: var(--display); font-weight: 400; color: var(--plum); font-size: 26px; margin: 0 0 6px; }
    .pinrow { margin-top: 30px; }
    .pinrow-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px 16px; margin: 0 0 14px; }
    .pinrow-head h3 { font-family: var(--display); font-weight: 500; color: var(--ink); font-size: 20px; margin: 0; }
    .pinrow-board { font-size: 13.5px; color: var(--ink-soft); margin: 0; }
    .pins-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 22px; }
    .pincard { display: flex; flex-direction: column; gap: 8px; }
    .pincard-img { position: relative; display: block; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; }
    .pincard-img img { width: 100%; height: auto; display: block; background: var(--paper-2); aspect-ratio: 2 / 3; object-fit: cover; }
    .pincard-tpl { position: absolute; top: 8px; left: 8px; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; background: rgba(46,52,47,.7); color: #F9F1EA; padding: 3px 9px; border-radius: 999px; }
    .pincard-tpl.is-new { background: #89494b; }
    .pincard-actions { display: flex; gap: 8px; }
    .pincard-save { flex: 1; text-align: center; background: #E60023; color: #fff; font-weight: 600; font-size: 13px; padding: 8px 10px; border-radius: 999px; }
    .pincard-save:hover { background: #c9001e; color: #fff; }
    .pincard-copy { flex: 1; font-family: inherit; font-size: 13px; padding: 7px 10px; border-radius: 999px; border: 1px solid var(--line); background: var(--paper); color: var(--ink); cursor: pointer; }
    .pincard-copy:hover { border-color: var(--plum); color: var(--plum); }
    .pincard-copy.copied { border-color: var(--plum); color: var(--plum); }
  </style>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.pincard-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.clip || '');
          const prev = btn.textContent;
          btn.classList.add('copied');
          btn.textContent = 'Copied ✓';
          setTimeout(() => { btn.classList.remove('copied'); btn.textContent = prev; }, 1600);
        } catch (e) {}
      });
    });
  </script>
</BaseLayout>
