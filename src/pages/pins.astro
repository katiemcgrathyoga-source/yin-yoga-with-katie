---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { journalPinVariants, type JournalVariant } from '../lib/journalPin';

// Katie's private pinning console (noindex, unlisted). Every journal post, pose and
// routine, rendered by /pin/journal.png in all four handoff variants — pick the one
// that fits the board, Save it, or copy the image+link for a scheduler.
const site = Astro.site!;
const enc = encodeURIComponent;
const VARIANTS: JournalVariant[] = ['arch', 'oat-frame', 'split', 'card'];

type Card = {
  title: string;
  board: string;
  url: string;
  description: string;
  pins: { variant: JournalVariant; img: string; save: string; clip: string }[];
};

// Build the four-variant pin set for one content item.
function makeCard(o: {
  title: string;
  board: string;
  path: string;
  description: string;
  eyebrow: string;
  meta?: string;
  excerpt?: string;
  photo?: string | null;
}): Card {
  const url = new URL(o.path, site).href;
  const variants = journalPinVariants(site, {
    title: o.title,
    eyebrow: o.eyebrow,
    meta: o.meta,
    excerpt: o.excerpt,
    photo: o.photo,
  });
  const pins = VARIANTS.map((variant) => {
    const img = variants[variant];
    const save = `https://www.pinterest.com/pin/create/button/?url=${enc(url)}&media=${enc(img)}&description=${enc(o.description)}`;
    const clip = `${o.title}\n\n${o.description}\n\nImage: ${img}\nLink: ${url}`;
    return { variant, img, save, clip };
  });
  return { title: o.title, board: o.board, url, description: o.description, pins };
}

const realPhoto = (p?: string) => (p && !p.includes('pose-placeholder') ? p : null);

// Journal posts.
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());
const postCards = posts.map((post) => {
  const d = post.data;
  return makeCard({
    title: d.title,
    board: 'From the journal',
    path: `/blog/${d.slug}/`,
    description: d.seo_description ?? d.description,
    eyebrow: 'From the journal',
    excerpt: d.description,
    photo: realPhoto(d.hero),
  });
});

// Poses (photo poses first — they read best in the split/card variants).
const poses = (await getCollection('poses')).sort((a, b) => {
  const pa = realPhoto(a.data.images?.[0]) ? 0 : 1;
  const pb = realPhoto(b.data.images?.[0]) ? 0 : 1;
  return pa - pb || a.data.name_en.localeCompare(b.data.name_en);
});
const poseCards = poses.map((pose) => {
  const d = pose.data;
  return makeCard({
    title: d.name_en,
    board: 'Yin Yoga Poses',
    path: `/poses/${d.slug}/`,
    description: d.seo_description,
    eyebrow: 'Pose library',
    // Never reveal the hold time on a pin (handoff rule): "Long hold" + areas.
    meta: `Long hold · ${d.target_areas.slice(0, 2).join(' & ')}`,
    excerpt: d.benefits[0],
    photo: realPhoto(d.images?.[0]),
  });
});

// Routines.
const poseBy = new Map((await getCollection('poses')).map((p) => [p.data.slug, p.data]));
const routines = (await getCollection('routines')).sort((a, b) => a.data.minutes - b.data.minutes);
const routineCards = routines.map((r) => {
  const d = r.data;
  const heroPose = (d.hero_pose && poseBy.get(d.hero_pose)) || poseBy.get(d.steps[0]?.pose);
  return makeCard({
    title: d.title,
    board: 'Yin Yoga Routines',
    path: `/routines/${d.slug}/`,
    description: d.summary,
    eyebrow: 'Routines',
    meta: `${d.minutes} minutes · ${d.level.replace(/-/g, ' ')}`,
    excerpt: d.summary,
    photo: realPhoto(heroPose?.images?.[0]),
  });
});

const sections = [
  { heading: 'Journal', lead: 'Every post as a text-led pin. The arch is the canonical one saved as og:image; the others give you variety for different boards.', cards: postCards },
  { heading: 'Poses', lead: 'Every pose in four looks — the split (full photo) and card variants read best where there’s a photo. Board: Yin Yoga Poses.', cards: poseCards },
  { heading: 'Routines', lead: 'Each routine as a pin. Meta shows the length and level — never the individual hold times. Board: Yin Yoga Routines.', cards: routineCards },
];
---

<BaseLayout title="Pin console" description="Private pinning console" noindex={true}>
  <div class="wrap pins">
    <h1>Pin console</h1>
    <p class="pins-lead">
      Every journal post, pose and routine, rendered on-brand at 1000×1500 in all four pin variants
      (<strong>arch · oat-frame · split · card</strong>). <strong>Save now</strong> pins immediately;
      <strong>Copy</strong> grabs the image, title, description and link for Pinterest's scheduler or Buffer.
      Pin 2–3 variants per item, spaced a day or two apart.
    </p>

    {sections.map((sec) => (
      <section class="pins-sec">
        <h2>{sec.heading}</h2>
        <p class="pins-lead">{sec.lead}</p>
        {sec.cards.map((card) => (
          <div class="pinrow">
            <div class="pinrow-head">
              <h3>{card.title}</h3>
              <p class="pinrow-board">Board: <strong>{card.board}</strong></p>
            </div>
            <div class="pins-grid">
              {card.pins.map((pin) => (
                <div class="pincard">
                  <a href={pin.save} target="_blank" rel="noopener noreferrer" class="pincard-img">
                    <img src={pin.img} alt={`${card.title} — ${pin.variant} pin`} loading="lazy" width="200" height="300" />
                    <span class="pincard-tpl">{pin.variant}</span>
                  </a>
                  <div class="pincard-actions">
                    <a class="pincard-save" href={pin.save} target="_blank" rel="noopener noreferrer">Save</a>
                    <button type="button" class="pincard-copy" data-clip={pin.clip}>Copy</button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </section>
    ))}
  </div>

  <style>
    .pins { padding: 40px 22px 90px; }
    .pins h1 { font-family: var(--display); color: var(--plum); font-size: 40px; margin: 0 0 10px; }
    .pins-lead { color: var(--ink-soft); max-width: 72ch; margin: 0; line-height: 1.6; }
    .pins-sec { margin-top: 48px; border-top: 1px solid var(--line); padding-top: 28px; }
    .pins-sec h2 { font-family: var(--display); font-weight: 400; color: var(--plum); font-size: 26px; margin: 0 0 6px; }
    .pinrow { margin-top: 30px; }
    .pinrow-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px 16px; margin: 0 0 14px; }
    .pinrow-head h3 { font-family: var(--display); font-weight: 500; color: var(--ink); font-size: 20px; margin: 0; }
    .pinrow-board { font-size: 13.5px; color: var(--ink-soft); margin: 0; }
    .pins-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 22px; }
    .pincard { display: flex; flex-direction: column; gap: 8px; }
    .pincard-img { position: relative; display: block; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; }
    .pincard-img img { width: 100%; height: auto; display: block; background: var(--paper-2); aspect-ratio: 2 / 3; object-fit: cover; }
    .pincard-tpl { position: absolute; top: 8px; left: 8px; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; background: rgba(46,52,47,.7); color: #F9F1EA; padding: 3px 9px; border-radius: 999px; }
    .pincard-actions { display: flex; gap: 8px; }
    .pincard-save { flex: 1; text-align: center; background: #E60023; color: #fff; font-weight: 600; font-size: 13px; padding: 8px 10px; border-radius: 999px; }
    .pincard-save:hover { background: #c9001e; color: #fff; }
    .pincard-copy { flex: 1; font-family: inherit; font-size: 13px; padding: 7px 10px; border-radius: 999px; border: 1px solid var(--line); background: var(--paper); color: var(--ink); cursor: pointer; }
    .pincard-copy:hover { border-color: var(--plum); color: var(--plum); }
    .pincard-copy.copied { border-color: var(--plum); color: var(--plum); }
  </style>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.pincard-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(btn.dataset.clip || '');
          const prev = btn.textContent;
          btn.classList.add('copied');
          btn.textContent = 'Copied ✓';
          setTimeout(() => { btn.classList.remove('copied'); btn.textContent = prev; }, 1600);
        } catch (e) {}
      });
    });
  </script>
</BaseLayout>
