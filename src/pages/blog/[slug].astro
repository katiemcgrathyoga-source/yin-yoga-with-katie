---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';
import { PROGRAMS } from '../../data/programs';
import { journalPinUrl } from '../../lib/journalPin';
import katieHello from '../../assets/katie-hello.jpg';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const d = post.data;
// One CTA per post: a specific program when set (the blueprint's conversion target),
// otherwise the site-wide free-retreat email capture.
const ctaProgram = d.cta_program ? PROGRAMS.find((p) => p.slug === d.cta_program) : undefined;
const { Content } = await render(post);
const fmt = (date: Date) => new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(date);
const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readMin = Math.max(1, Math.round(words / 200));

const ogImage = new URL('/og/card.png', Astro.site);
ogImage.searchParams.set('t', d.title.slice(0, 70));
ogImage.searchParams.set('s', d.description.slice(0, 90));

// Article structured data (E-E-A-T + rich results), per the content blueprint.
const heroAbs = d.hero ? new URL(d.hero, Astro.site).href : ogImage.href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.seo_description ?? d.description,
  datePublished: d.published.toISOString(),
  dateModified: (d.updated ?? d.published).toISOString(),
  image: heroAbs,
  author: {
    '@type': 'Person',
    name: 'Katie McGrath',
    description: 'Yin Yoga & Yoga Nidra teacher',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Yin Yoga with Katie',
    logo: { '@type': 'ImageObject', url: new URL('/brand/submark-deep-sage.png', Astro.site).href },
  },
  mainEntityOfPage: new URL(`/blog/${d.slug}`, Astro.site).href,
};

// Share links — let readers distribute the post for us (Pinterest is the priority channel).
const postUrl = new URL(`/blog/${d.slug}/`, Astro.site).href;
const enc = encodeURIComponent;
// Branded 1000×1500 Journal Pin (rendered by /pin/journal.png) — the arch variant
// is this post's canonical pin: og:image so "Pin it"/Rich Pins grab a tall on-brand
// image, and the Pinterest share media so saving pins it too (not the landscape hero).
const journalPin = journalPinUrl(Astro.site, {
  variant: 'arch',
  title: d.title,
  eyebrow: 'From the journal',
  excerpt: d.description,
  photo: d.hero,
});
const shareLinks = {
  pinterest: `https://www.pinterest.com/pin/create/button/?url=${enc(postUrl)}&media=${enc(journalPin)}&description=${enc(d.description)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${enc(postUrl)}`,
  x: `https://twitter.com/intent/tweet?url=${enc(postUrl)}&text=${enc(d.title)}`,
};
---

<BaseLayout
  title={`${d.seo_title ?? d.title} — Yin Yoga with Katie`}
  description={d.seo_description ?? d.description}
  ogType="article"
  image={journalPin}
  jsonLd={jsonLd}
>
  <article class="journal">
    <p class="jr-back"><a href="/blog">← the journal</a></p>

    <header class="jr-hero">
      <p class="jr-eyebrow">the journal{d.eyebrow_tag ? ` · ${d.eyebrow_tag}` : ''}</p>
      <h1>{d.title}</h1>
      {d.subtitle && <p class="jr-sub">{d.subtitle}</p>}
      <p class="jr-meta">{fmt(d.published)} &nbsp;·&nbsp; {readMin} minute read &nbsp;·&nbsp; by Katie</p>
      {d.hero && (
        <figure class="jr-heroimg" data-orient>
          <img src={d.hero} alt="" loading="eager" />
          {d.hero_caption && <figcaption>{d.hero_caption}</figcaption>}
        </figure>
      )}
    </header>

    <div class="jr-body prose blog-prose">
      <Content />
    </div>

    <div class="blog-share" data-share-url={postUrl}>
      <span class="blog-share-label">Share</span>
      <a class="blog-share-btn blog-share-pin" href={shareLinks.pinterest} target="_blank" rel="noopener noreferrer" aria-label="Save to Pinterest" title="Save to Pinterest">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C24.007 5.367 18.641.001 12.017.001z"/></svg>
      </a>
      <a class="blog-share-btn blog-share-fb" href={shareLinks.facebook} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" title="Share on Facebook">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"/></svg>
      </a>
      <a class="blog-share-btn blog-share-x" href={shareLinks.x} target="_blank" rel="noopener noreferrer" aria-label="Share on X" title="Share on X">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
      </a>
      <button type="button" class="blog-share-btn blog-share-copy" aria-label="Copy link" title="Copy link">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </div>

    {ctaProgram && (
      <aside class="blog-cta">
        <p class="eyebrow">Practise this</p>
        <h2>{ctaProgram.title}</h2>
        <p>{ctaProgram.outcome} {ctaProgram.blurb}</p>
        <a class="btn-cta" href={`/programs/${ctaProgram.slug}`}>Start the program →</a>
      </aside>
    )}

    <Cta />

    <aside class="jr-author">
      <span class="jr-author-photo">
        <Image src={katieHello} alt="Katie McGrath" width={168} height={168} loading="lazy" />
      </span>
      <div class="jr-author-copy">
        <p class="jr-author-eyebrow">written by</p>
        <p class="jr-author-name">Katie McGrath</p>
        <p class="jr-author-bio">
          Yin Yoga &amp; Yoga Nidra teacher based in Taipei, teaching since 2018. She makes slow,
          gentle classes for tired minds and bodies. <a href="/blog">More from the Journal →</a>
        </p>
      </div>
      <p class="jr-author-sign" aria-hidden="true">katie</p>
    </aside>
  </article>

  <script>
    // Copy-link share button
    document.querySelectorAll<HTMLButtonElement>('.blog-share-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.closest('.blog-share')?.getAttribute('data-share-url') || location.href;
        try {
          await navigator.clipboard.writeText(url);
          btn.classList.add('copied');
          btn.setAttribute('title', 'Copied!');
          setTimeout(() => { btn.classList.remove('copied'); btn.setAttribute('title', 'Copy link'); }, 1600);
        } catch (e) {}
      });
    });

    // Orientation-aware framing: portrait photos take the arch, landscape (lying-down) get the rounded frame.
    document.querySelectorAll<HTMLElement>('[data-orient]').forEach((el) => {
      const img = el.querySelector('img');
      if (!img) return;
      const apply = () => {
        const landscape = img.naturalWidth >= img.naturalHeight;
        el.classList.toggle('is-landscape', landscape);
        el.classList.toggle('is-portrait', !landscape);
      };
      if (img.complete && img.naturalWidth) apply();
      else img.addEventListener('load', apply);
    });
  </script>
</BaseLayout>
