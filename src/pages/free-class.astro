---
import BaseLayout from '../layouts/BaseLayout.astro';

// Branded OG card for shares.
const ogImage = new URL('/og/card.png', Astro.site);
ogImage.searchParams.set('t', 'A free 2-hour Yin retreat');
ogImage.searchParams.set('s', 'Yin, restorative & Yoga Nidra — deep rest, on the house');

// MailerLite form (account 2503148, form L6O8I1). The form posts straight to
// MailerLite; the free class is delivered by the welcome email automation.
const ML_ACTION = 'https://assets.mailerlite.com/jsonp/2503148/forms/192665473777665865/subscribe';
---

<BaseLayout
  title="A Free 2-Hour Yin Yoga Retreat at Home — Yin Yoga with Katie"
  description="Pop in your email and I'll send you a full two-hour Yin, restorative and Yoga Nidra retreat, free — two hours of pure rest to calm your nervous system. Yours to keep."
  image={ogImage.href}
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">A gift from me</p>
      <h1>A free two-hour retreat</h1>
      <p class="alt">yin, restorative & yoga nidra — two hours of deep rest, on the house</p>
      <p class="cta-members">✦ A members-only class — free for you</p>
    </header>

    <p class="page-intro">
      Pop your email below and I'll send you a complete two-hour mini-retreat to keep and return to
      any time. It's a slow, guided journey through Yin, restorative yoga and Yoga Nidra — designed
      to calm your nervous system and melt off a busy, stressful week. Nowhere to be, nothing to
      keep up with. Come as you are.
    </p>

    <section class="lm">
      <ul class="lm-points">
        <li>A full two-hour guided retreat — normally members-only, free to keep</li>
        <li>Yin + restorative yoga + Yoga Nidra + breathwork</li>
        <li>Deep rest for your nervous system — real stress relief</li>
      </ul>

      <form
        class="lm-form"
        id="lm-form"
        action={ML_ACTION}
        method="post"
        target="ml_frame"
        aria-label="Get your free class"
      >
        <label class="sr-only" for="lm-name">First name</label>
        <input
          id="lm-name"
          type="text"
          name="fields[name]"
          placeholder="First name"
          autocomplete="given-name"
          required
          aria-required="true"
        />
        <label class="sr-only" for="lm-email">Email address</label>
        <input
          id="lm-email"
          type="email"
          name="fields[email]"
          placeholder="you@email.com"
          autocomplete="email"
          required
          aria-required="true"
        />
        <input type="hidden" name="ml-submit" value="1" />
        <input type="hidden" name="anticsrf" value="true" />
        <button type="submit" class="btn-cta">Send me the free retreat →</button>
      </form>

      <p class="lm-fine">No spam, ever. Unsubscribe any time. I'll only send Yin.</p>

      <div class="lm-success" id="lm-success" hidden role="status">
        <h2>Check your inbox 🌙</h2>
        <p>
          Your two-hour retreat is on its way. If it's not there in a minute or two, peek in your
          spam or promotions folder and mark it "not spam" so you don't miss what's next.
        </p>
        <a class="lm-success-link" href="/">← Explore the free class library</a>
      </div>
    </section>

    <iframe name="ml_frame" id="ml_frame" class="lm-frame" title="Sign-up" tabindex="-1" aria-hidden="true"></iframe>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('lm-form') as HTMLFormElement | null;
  const success = document.getElementById('lm-success');
  const fine = document.querySelector('.lm-fine') as HTMLElement | null;
  form?.addEventListener('submit', () => {
    // The POST goes to MailerLite in the hidden iframe; show our own thank-you.
    setTimeout(() => {
      form.hidden = true;
      if (fine) fine.hidden = true;
      if (success) success.hidden = false;
      success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 350);
  });
</script>
