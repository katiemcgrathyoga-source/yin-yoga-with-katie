---
import BaseLayout from '../layouts/BaseLayout.astro';

// Branded OG card for shares.
const ogImage = new URL('/og/card.png', Astro.site);
ogImage.searchParams.set('t', 'A free Post-Run Reset for runners');
ogImage.searchParams.set('s', '10 minutes of Yin to loosen tight hips, hamstrings & calves — free');

// MailerLite form (account 2503148). The form posts straight to MailerLite; the
// Post-Run Reset is delivered by the welcome automation.
//
// TODO (Katie's side): point this at a DEDICATED "Runners" MailerLite form so
// runner signups trigger the Post-Run Reset automation (delivery + bridge email),
// NOT the 2-hour-retreat series. `signup_source: "runner"` is sent regardless, so
// you can alternatively branch/segment the automation on that field on the shared
// form. Until one of those is set up, runner signups will get the retreat email.
const ML_ACTION = 'https://assets.mailerlite.com/jsonp/2503148/forms/192665473777665865/subscribe';
---

<BaseLayout
  title="A Free 10-Minute Post-Run Reset for Runners — Yin Yoga with Katie"
  description="Free for runners: a 10-minute follow-along Yin Post-Run Reset to loosen the tight hips, hamstrings and calves running builds up. Pop in your email and I'll send it — yours to keep."
  image={ogImage.href}
  noindex={true}
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">For runners</p>
      <h1>The ten minutes after your run that keep you running.</h1>
      <p class="alt">a free follow-along post-run reset — loosen tight hips, hamstrings & calves</p>
    </header>

    <p class="page-intro">
      Pop your email below and I'll send you a free follow-along Post-Run Reset — ten quiet minutes
      to loosen the hips, hamstrings and calves running tightens, so the stiffness lets go before it
      sets in. Do it right after your next run. Yours to keep.
    </p>

    <section class="lm">
      <ul class="lm-points">
        <li>A short, follow-along Yin routine — made to do right after a run</li>
        <li>Loosens the hips, hamstrings and calves running tightens most</li>
        <li>No flexibility needed, no props, nothing to keep up with</li>
      </ul>

      <form
        class="lm-form"
        id="lm-form"
        action={ML_ACTION}
        method="post"
        target="ml_frame"
        aria-label="Get your free Post-Run Reset"
      >
        <label class="sr-only" for="lm-name">First name</label>
        <input
          id="lm-name"
          type="text"
          name="fields[name]"
          placeholder="First name"
          autocomplete="given-name"
          required
          aria-required="true"
        />
        <label class="sr-only" for="lm-email">Email address</label>
        <input
          id="lm-email"
          type="email"
          name="fields[email]"
          placeholder="you@email.com"
          autocomplete="email"
          required
          aria-required="true"
        />
        <input type="hidden" name="fields[signup_source]" value="runner" />
        <input type="hidden" name="ml-submit" value="1" />
        <input type="hidden" name="anticsrf" value="true" />
        <button type="submit" class="btn-cta">Send me the Post-Run Reset →</button>
      </form>

      <p class="lm-fine">No spam, ever. Unsubscribe any time. I'll only send Yin.</p>

      <div class="lm-success" id="lm-success" hidden role="status">
        <h2>Check your inbox 🌙</h2>
        <p>
          Your Post-Run Reset is on its way. Roll out your mat after your next run and follow along.
          If it's not there in a minute, peek in your promotions or spam folder so you don't miss
          what's next.
        </p>
        <a class="lm-success-link" href="/">← Explore the free class library</a>
      </div>
    </section>

    <iframe name="ml_frame" id="ml_frame" class="lm-frame" title="Sign-up" tabindex="-1" aria-hidden="true"></iframe>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('lm-form') as HTMLFormElement | null;
  const success = document.getElementById('lm-success');
  const fine = document.querySelector('.lm-fine') as HTMLElement | null;
  form?.addEventListener('submit', () => {
    // The POST goes to MailerLite in the hidden iframe; show our own thank-you.
    setTimeout(() => {
      form.hidden = true;
      if (fine) fine.hidden = true;
      if (success) success.hidden = false;
      success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 350);
  });
</script>
