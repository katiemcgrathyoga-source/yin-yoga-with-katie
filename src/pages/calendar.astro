---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendarNav from '../components/CalendarNav.astro';
import { derivedThumb, lenLabel, videoHeadline } from '../lib/video';
import { MONTHLY_PLAN, MONTHLY_INTRO } from '../data/monthlyPlan';
import { SITE } from '../data/site';

const videos = await getCollection('videos');
const bySlug = new Map(videos.map((v) => [v.data.slug, v.data]));
const weekly = MONTHLY_PLAN.map((s) => bySlug.get(s));

// Current month, baked at build (a rebuild rolls it forward).
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();
const monthName = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' }).format(now);
const daysInMonth = new Date(year, month + 1, 0).getDate();
const lead = (new Date(year, month, 1).getDay() + 6) % 7; // Monday-first offset

const cells: (number | null)[] = [];
for (let i = 0; i < lead; i++) cells.push(null);
for (let d = 1; d <= daysInMonth; d++) cells.push(d);
while (cells.length % 7) cells.push(null);
const weeks: (number | null)[][] = [];
for (let i = 0; i < cells.length; i += 7) weeks.push(cells.slice(i, i + 7));

const mon = (d: number) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(new Date(year, month, d));
const rangeLabel = (week: (number | null)[]) => {
  const days = week.filter((d): d is number => d !== null);
  return days.length ? `${mon(days[0])} – ${mon(days[days.length - 1])}` : '';
};

const signup = SITE.calendarSignupAction;

const ogImage = new URL('/og/card.png', Astro.site);
ogImage.searchParams.set('t', 'My Monthly Yin Calendar');
ogImage.searchParams.set('s', 'One class a week — a rhythm you can keep');
---

<BaseLayout
  title="This Month's Yin Yoga Calendar — Yin Yoga with Katie"
  description="Your Yin Yoga rhythm for the month — one class to practise each week, any day that suits you. Sign up to get a gentle email each week telling you which class to do."
  image={ogImage.href}
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">Practice · This Month</p>
      <h1>This Month</h1>
      <p class="alt">one class a week — a gentle rhythm you can keep</p>
    </header>

    <CalendarNav active="month" />

    <p class="page-intro">{MONTHLY_INTRO}</p>

    <section class="cal-signup-wrap" aria-label="Weekly reminders">
      <div class="cal-signup-card">
        <h2>Never miss a week</h2>
        <p>Drop your email and I'll send a gentle nudge each week telling you which class to do.</p>
        {
          signup ? (
            <>
              <form class="cal-signup" id="cal-signup" action={signup} method="post" target="cal_frame">
                <input type="text" name="fields[name]" placeholder="First name" autocomplete="given-name" required aria-label="First name" />
                <input type="email" name="fields[email]" placeholder="you@email.com" autocomplete="email" required aria-label="Email" />
                <input type="hidden" name="ml-submit" value="1" />
                <input type="hidden" name="anticsrf" value="true" />
                <button type="submit" class="btn-cta">Notify me each week →</button>
              </form>
              <p class="cal-fine">No spam, ever. Unsubscribe any time.</p>
              <div class="cal-success" id="cal-success" hidden role="status">
                <p><strong>You're in 🌙</strong> I'll email you each week with this week's class.</p>
              </div>
              <iframe name="cal_frame" class="lm-frame" title="Sign-up" tabindex="-1" aria-hidden="true"></iframe>
            </>
          ) : (
            <p class="cal-soon">Weekly email reminders are coming soon — check back shortly.</p>
          )
        }
      </div>
    </section>

    <h2 class="cal-month-title">{monthName}</h2>

    <div class="month-weeks">
      {
        weeks.map((week, i) => {
          const v = weekly[Math.min(i, weekly.length - 1)];
          return (
            <div class="mw" data-week={i}>
              <div class="mw-dates">
                <div class="mw-range">Week {i + 1} · {rangeLabel(week)}</div>
                <div class="mw-days" aria-hidden="true">
                  {['M', 'T', 'W', 'T', 'F', 'S', 'S'].map((dl) => <span class="mw-dl">{dl}</span>)}
                  {week.map((d) => (
                    <span class="mw-day" data-date={d ?? ''}>{d ?? ''}</span>
                  ))}
                </div>
              </div>
              <div class="mw-video">
                {v ? (
                  <a class="mw-class" href={`/videos/${v.slug}`}>
                    <span class="mw-thumb">
                      <img src={derivedThumb(v)} alt={v.title} loading="lazy" width="480" height="270" />
                      <span class="day-len">{lenLabel(v)}</span>
                    </span>
                    <span class="mw-info">
                      <span class="mw-eyebrow">This week's class</span>
                      <span class="mw-title">{videoHeadline(v)}</span>
                    </span>
                  </a>
                ) : (
                  <p class="mw-rest">A week to rest, or repeat a favourite.</p>
                )}
              </div>
            </div>
          );
        })
      }
    </div>

    <footer>
      <p class="src">
        Practise each week's class on whatever day suits you. Prefer your own plan?
        <a href="/calendar/build">Build your own calendar →</a>
      </p>
    </footer>
  </div>
</BaseLayout>

<script>
  // Highlight today and the current week (accurate regardless of last build date).
  const now = new Date();
  const cell = [...document.querySelectorAll<HTMLElement>('.mw-day')].find((c) => c.dataset.date === String(now.getDate()));
  if (cell) {
    cell.classList.add('is-today');
    cell.closest('.mw')?.classList.add('is-this-week');
    cell.closest('.mw')?.scrollIntoView?.({ block: 'nearest' });
  }

  // Lead-magnet-style success toggle for the weekly signup.
  const form = document.getElementById('cal-signup') as HTMLFormElement | null;
  const success = document.getElementById('cal-success');
  form?.addEventListener('submit', () => {
    setTimeout(() => {
      form.hidden = true;
      document.querySelector('.cal-fine')?.setAttribute('hidden', '');
      success?.removeAttribute('hidden');
    }, 350);
  });
</script>
