---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Poses are the reference layer beneath the video library. This is their browsable
// index. Ordered by how foundational/common each pose is — measured by how often it
// appears across Katie's classes and routines — so the shapes she teaches most lead,
// and obscure ones fall to the end. Ties break alphabetically.
const refCount = new Map<string, number>();
const bump = (slug: string, n = 1) => refCount.set(slug, (refCount.get(slug) ?? 0) + n);
for (const v of await getCollection('videos')) {
  if (v.data.length_minutes < 10) continue; // ignore removed shorts
  for (const s of v.data.poses_featured) bump(s);
  for (const c of v.data.chapters) if (c.pose) bump(c.pose);
}
for (const r of await getCollection('routines')) for (const st of r.data.steps) bump(st.pose);

const poses = (await getCollection('poses')).sort(
  (a, b) =>
    (refCount.get(b.data.slug) ?? 0) - (refCount.get(a.data.slug) ?? 0) ||
    a.data.name_en.localeCompare(b.data.name_en),
);

const titleCase = (s: string) => s.replace(/\b\w/g, (c) => c.toUpperCase());
const uniq = (arr: string[]) => [...new Set(arr)].sort((a, b) => a.localeCompare(b));

// Target areas — a FIXED, curated set of ≤10 main body areas so the filter stays
// tidy. Each pose's many raw target_areas map into these buckets; unlisted raw
// values aren't surfaced as filters. Edit THIS list to change the filter.
const AREA_BUCKETS = [
  { key: 'hips', label: 'Hips', match: (a: string) => /hips|outer hip|glute|it band/.test(a) },
  { key: 'hip-flexors', label: 'Hip flexors', match: (a: string) => /hip flexor|front of thigh|quad/.test(a) },
  { key: 'groin', label: 'Groin & inner thigh', match: (a: string) => /groin|inner thigh/.test(a) },
  { key: 'hamstrings', label: 'Hamstrings', match: (a: string) => /hamstring/.test(a) },
  { key: 'lower-back', label: 'Lower back', match: (a: string) => /lower back|low back|sacrum/.test(a) },
  { key: 'spine', label: 'Spine', match: (a: string) => /\bspine\b|side body|oblique|rib/.test(a) },
  { key: 'shoulders', label: 'Shoulders', match: (a: string) => /shoulder|upper back/.test(a) },
  { key: 'chest', label: 'Chest', match: (a: string) => /chest|pectoral|lung/.test(a) },
  { key: 'neck', label: 'Neck', match: (a: string) => /neck|throat/.test(a) },
  { key: 'legs-feet', label: 'Legs & feet', match: (a: string) => /knee|ankle|feet|foot|shin|toe|\bcalf\b|\blegs?\b/.test(a) },
];
const areaKeys = (p: (typeof poses)[number]) => {
  const set = new Set<string>();
  for (const raw of p.data.target_areas) {
    const a = raw.toLowerCase();
    for (const b of AREA_BUCKETS) if (b.match(a)) set.add(b.key);
  }
  return [...set];
};
const areaLabel = (key: string) => AREA_BUCKETS.find((b) => b.key === key)!.label;
// Keep each filter section to the 5 most-common values so the page stays tidy.
const areaCount = (key: string) => poses.filter((p) => areaKeys(p).includes(key)).length;
const presentAreas = AREA_BUCKETS.filter((b) => poses.some((p) => areaKeys(p).includes(b.key)))
  .sort((a, b) => areaCount(b.key) - areaCount(a.key))
  .slice(0, 5);

const merCount = (m: string) => poses.filter((p) => p.data.meridians.includes(m)).length;
const meridians = uniq(poses.flatMap((p) => p.data.meridians))
  .sort((a, b) => merCount(b) - merCount(a))
  .slice(0, 5);
const levelOrder = ['beginner', 'intermediate', 'advanced'];
const levels = uniq(poses.map((p) => p.data.accessibility)).sort(
  (a, b) => levelOrder.indexOf(a) - levelOrder.indexOf(b),
);
---

<BaseLayout
  title="Yin Yoga Pose Reference — Yin Yoga with Katie"
  description="A reference library of yin yoga poses — cues, benefits, hold times and cautions. Browse by target area, meridian and level, or open a class to practise them in sequence."
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">Yin Yoga · Reference</p>
      <h1>Poses</h1>
      <p class="alt">the shapes behind the classes — cues, benefits and cautions for each</p>
    </header>

    <p class="page-intro">
      Yin Yoga works deep — into the connective tissue, joints and fascia — by holding
      simple, floor-based shapes for several minutes at a time. This is a plain-language
      reference to the poses I use in my classes: what each one targets, how long to hold
      it, which props help, and what to take care with. Open any pose to read it, set the
      built-in hold timer, or jump to the classes it appears in.
    </p>

    <section>
      <div class="filters" id="filters">
        <div class="facet">
          <span class="facet-label">Target areas</span>
          <div class="chips">
            {presentAreas.map((b) => (
              <button type="button" class="chip" data-facet="area" data-value={b.key} aria-pressed="false">{b.label}</button>
            ))}
          </div>
        </div>

        {meridians.length > 0 && (
          <div class="facet">
            <span class="facet-label">Meridians</span>
            <div class="chips">
              {meridians.map((m) => (
                <button type="button" class="chip" data-facet="meridian" data-value={m} aria-pressed="false">{m}</button>
              ))}
            </div>
          </div>
        )}

        <div class="facet">
          <span class="facet-label">Level</span>
          <div class="chips">
            {levels.map((l) => (
              <button type="button" class="chip" data-facet="level" data-value={l} aria-pressed="false">{titleCase(l)}</button>
            ))}
          </div>
        </div>

        <div class="filter-meta">
          <button type="button" class="chip chip-clear" id="clear-filters" hidden>Clear filters</button>
          <span class="count" id="result-count" aria-live="polite"></span>
        </div>
      </div>

      <div class="tiles" id="tiles">
        {poses.map((p) => (
          <a
            class="tile"
            href={`/poses/${p.data.slug}`}
            data-tile
            data-areas={areaKeys(p).join('|')}
            data-meridians={p.data.meridians.join('|')}
            data-level={p.data.accessibility}
          >
            <div class="tile-thumb">
              {p.data.images.length > 0 ? (
                <img class="tile-img pose" src={p.data.images[0]} alt={p.data.name_en} loading="lazy" />
              ) : (
                <div class="tile-img pose tile-noimg">{p.data.name_en}</div>
              )}
            </div>
            <div class="tile-body">
              <h3 class="tile-name">{p.data.name_en}</h3>
              <div class="tile-tags">
                {areaKeys(p).slice(0, 3).map((k) => <span class="tag">{areaLabel(k)}</span>)}
                <span class="tag tag-level">{titleCase(p.data.accessibility)}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <p class="empty" id="empty" hidden>No poses match those filters yet.</p>
    </section>

    <footer>
      <p class="src">Poses are the building blocks classes are built from.</p>
    </footer>
  </div>
</BaseLayout>

<script>
  // Client-side faceted filtering — OR within a facet, AND across.
  const tiles = Array.from(document.querySelectorAll<HTMLElement>('[data-tile]'));
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip[data-facet]'));
  const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement | null;
  const countEl = document.getElementById('result-count');
  const emptyEl = document.getElementById('empty');

  const active: Record<string, Set<string>> = {
    area: new Set(),
    meridian: new Set(),
    level: new Set(),
  };

  const split = (v: string | undefined) => (v ? v.split('|').filter(Boolean) : []);

  function apply() {
    let visible = 0;
    for (const tile of tiles) {
      const areas = split(tile.dataset.areas);
      const meridians = split(tile.dataset.meridians);
      const level = tile.dataset.level ?? '';

      const okArea = active.area.size === 0 || areas.some((a) => active.area.has(a));
      const okMer = active.meridian.size === 0 || meridians.some((m) => active.meridian.has(m));
      const okLvl = active.level.size === 0 || active.level.has(level);

      const show = okArea && okMer && okLvl;
      tile.hidden = !show;
      if (show) visible++;
    }

    const anyActive = active.area.size + active.meridian.size + active.level.size > 0;
    if (clearBtn) clearBtn.hidden = !anyActive;
    if (emptyEl) emptyEl.hidden = visible > 0;
    if (countEl) {
      countEl.textContent = anyActive
        ? `${visible} of ${tiles.length} ${tiles.length === 1 ? 'pose' : 'poses'}`
        : '';
    }
  }

  for (const chip of chips) {
    chip.addEventListener('click', () => {
      const facet = chip.dataset.facet!;
      const value = chip.dataset.value!;
      const set = active[facet];
      if (set.has(value)) {
        set.delete(value);
        chip.setAttribute('aria-pressed', 'false');
        chip.classList.remove('active');
      } else {
        set.add(value);
        chip.setAttribute('aria-pressed', 'true');
        chip.classList.add('active');
      }
      apply();
    });
  }

  clearBtn?.addEventListener('click', () => {
    for (const key of Object.keys(active)) active[key].clear();
    for (const chip of chips) {
      chip.setAttribute('aria-pressed', 'false');
      chip.classList.remove('active');
    }
    apply();
  });

  apply();
</script>
