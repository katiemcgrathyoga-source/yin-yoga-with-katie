---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';
import PoseTimer from '../../components/PoseTimer.astro';

/**
 * One reusable template for every pose. `getStaticPaths` reads the whole
 * collection and emits a static page per file, keyed by each pose's `slug`.
 * Add a Markdown file to src/content/poses/ and a new page appears — no code.
 */
export async function getStaticPaths() {
  const poses = await getCollection('poses');
  return poses.map((pose) => ({
    params: { slug: pose.data.slug },
    props: { pose, poses },
  }));
}

const { pose, poses } = Astro.props;
const d = pose.data;

// Lookup of slug -> pose data, so related-pose links can show real names
// when the related pose already exists in the collection.
const bySlug = new Map(poses.map((p) => [p.data.slug, p.data]));

// Reverse of the routine→pose link: follow-along routines that feature this pose,
// shortest first. Only shown when at least one routine includes the pose.
const featuredRoutines = (await getCollection('routines'))
  .filter((r) => r.data.steps.some((s) => s.pose === d.slug))
  .sort((a, b) => a.data.minutes - b.data.minutes);

const titleCase = (s: string) =>
  s.replace(/\b\w/g, (c) => c.toUpperCase());
const humanise = (slug: string) =>
  titleCase(slug.replace(/-/g, ' '));

// --- schema.org HowTo, built from cues, hold_time and props ------------------
// totalTime = the largest minute figure found in hold_time, as ISO-8601 (PT#M).
const minuteFigures = (d.hold_time.match(/\d+/g) ?? []).map(Number);
const totalMinutes = minuteFigures.length ? Math.max(...minuteFigures) : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: d.name_en,
  description: d.seo_description,
  ...(totalMinutes ? { totalTime: `PT${totalMinutes}M` } : {}),
  ...(d.props.length
    ? { supply: d.props.map((name) => ({ '@type': 'HowToSupply', name })) }
    : {}),
  step: d.cues.map((text) => ({ '@type': 'HowToStep', text })),
};

const hasVideo = Boolean(d.youtube_video_id && d.youtube_video_id.trim());
const eyebrow = `Yin Yoga · ${titleCase(d.accessibility)}`;

// Branded OG card for link previews (matches the routine cards + completion badge).
const ogImage = new URL('/og/card.png', Astro.site);
ogImage.searchParams.set('t', d.name_en);
ogImage.searchParams.set('s', 'A Yin Yoga pose');

// FAQPage schema — rendered alongside the HowTo when the pose has FAQs.
const faqLd = d.faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: d.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

// Default target for the on-page hold timer (all poses carry hold_seconds; 180s is a safe fallback).
const holdSeconds = d.hold_seconds ?? 180;
---

<BaseLayout
  title={d.seo_title}
  description={d.seo_description}
  ogTitle={d.name_en}
  ogDescription={d.seo_description}
  ogType="article"
  image={ogImage.href}
  jsonLd={faqLd ? [jsonLd, faqLd] : jsonLd}
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{d.name_en}</h1>

      <div class="hold" aria-label="Recommended hold time">
        <span class="hold-eyebrow">Hold</span>
        <p class="hold-time">{d.hold_time}</p>
      </div>
    </header>

    {/* Single reference photo, directly under the hero. */}
    {
      d.images.length > 0 && (
        <figure class="pose-photo">
          <img
            src={d.images[0]}
            alt={`${d.name_en} yin yoga pose`}
            loading="lazy"
            onerror="this.closest('.pose-photo').remove()"
          />
        </figure>
      )
    }

    {/* Hold timer — set your length and let the shape do the work. */}
    <section class="timer-section">
      <h2>Time your hold</h2>
      <PoseTimer seconds={holdSeconds} holdLabel={d.hold_time} />
    </section>

    {/* Follow-along video — separate section, only when a video id is set. */}
    {
      hasVideo && (
        <section class="follow-along">
          <h2>Follow along</h2>
          <div class="video-embed">
            <iframe
              src={`https://www.youtube.com/embed/${d.youtube_video_id}`}
              title={`${d.name_en} — practice video`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </section>
      )
    }

    {
      featuredRoutines.length > 0 && (
        <section class="featured-in">
          <h2>Routines featuring this pose</h2>
          {featuredRoutines.map((r) => (
            <a href={`/routines/${r.data.slug}`}>
              {r.data.title}
              <span>{r.data.minutes} min · {r.data.summary}</span>
            </a>
          ))}
        </section>
      )
    }

    <section>
      <h2>How to do it</h2>
      <ol class="cues">
        {d.cues.map((cue) => <li>{cue}</li>)}
      </ol>
    </section>

    <section>
      <h2>Why practise it</h2>
      <ul class="plain">
        {d.benefits.map((b) => <li>{b}</li>)}
      </ul>
    </section>

    {
      (d.transitions_in.length > 0 || d.transitions_out.length > 0) && (
        <section>
          <h2>Coming in &amp; out</h2>
          <div class="transitions">
            {d.transitions_in.length > 0 && (
              <div>
                <h3>Into the pose</h3>
                <ul class="plain">
                  {d.transitions_in.map((t) => <li>{t}</li>)}
                </ul>
              </div>
            )}
            {d.transitions_out.length > 0 && (
              <div>
                <h3>Out of the pose</h3>
                <ul class="plain">
                  {d.transitions_out.map((t) => <li>{t}</li>)}
                </ul>
              </div>
            )}
          </div>
        </section>
      )
    }

    {
      d.cautions.length > 0 && (
        <section>
          <div class="cautions">
            <h2>Take care</h2>
            <ul class="plain">
              {d.cautions.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        </section>
      )
    }

    <section>
      <h2>At a glance</h2>
      <dl class="glance">
        <div class="row"><dt>Hold</dt><dd>{d.hold_time}</dd></div>
        <div class="row"><dt>Level</dt><dd>{titleCase(d.accessibility)}</dd></div>
        <div class="row">
          <dt>Target areas</dt>
          <dd>{d.target_areas.map((t) => <span class="tag">{t}</span>)}</dd>
        </div>
        {
          d.meridians.length > 0 && (
            <div class="row">
              <dt>Meridians</dt>
              <dd>{d.meridians.map((m) => <span class="tag">{m}</span>)}</dd>
            </div>
          )
        }
        {
          d.props.length > 0 && (
            <div class="row">
              <dt>Props</dt>
              <dd>{d.props.map((p) => <span class="tag">{p}</span>)}</dd>
            </div>
          )
        }
        {
          d.counterposes.length > 0 && (
            <div class="row">
              <dt>Counterpose</dt>
              <dd>{d.counterposes.join(' · ')}</dd>
            </div>
          )
        }
      </dl>
    </section>

    {
      d.faq.length > 0 && (
        <section class="faq-section">
          <h2>Common questions</h2>
          {d.faq.map((f) => (
            <details class="faq">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </section>
      )
    }

    <Cta
      eyebrow="Practise with me"
      heading="Ready to move?"
      body="Find this shape inside a full class — every one free to follow on YouTube. For a guided path, join the membership, or start with a free program."
    />

    {
      d.related_poses.length > 0 && (
        <section class="related">
          <h2>Related poses</h2>
          {d.related_poses.map((slug) => {
            const rel = bySlug.get(slug);
            return (
              <a href={`/poses/${slug}`}>
                {rel ? rel.name_en : humanise(slug)}
                {rel && <span>{rel.seo_description}</span>}
              </a>
            );
          })}
        </section>
      )
    }

    <footer>
      <p class="src">
        Content grounded in Bernie Clark, <em>The Complete Guide to Yin Yoga</em>.
        Original copy. Contraindications to be verified before publishing as advice.
      </p>
    </footer>
  </div>
</BaseLayout>
