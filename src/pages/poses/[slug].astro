---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';
import PoseTimer from '../../components/PoseTimer.astro';
import { videoHeadline } from '../../lib/video';
import { journalPinUrl } from '../../lib/journalPin';

/**
 * One reusable template for every pose. `getStaticPaths` reads the whole
 * collection and emits a static page per file, keyed by each pose's `slug`.
 * Add a Markdown file to src/content/poses/ and a new page appears — no code.
 */
export async function getStaticPaths() {
  const poses = await getCollection('poses');
  return poses.map((pose) => ({
    params: { slug: pose.data.slug },
    props: { pose, poses },
  }));
}

const { pose, poses } = Astro.props;
const d = pose.data;

// Lookup of slug -> pose data, so related-pose links can show real names
// when the related pose already exists in the collection.
const bySlug = new Map(poses.map((p) => [p.data.slug, p.data]));

// Reverse of the routine→pose link: follow-along routines that feature this pose,
// shortest first. Only shown when at least one routine includes the pose.
const featuredRoutines = (await getCollection('routines'))
  .filter((r) => r.data.steps.some((s) => s.pose === d.slug))
  .sort((a, b) => a.data.minutes - b.data.minutes);

// Full YouTube classes that feature this pose — best 3 (enriched first, then most
// watched). Shown at the very bottom as an "also in these classes" cross-link.
const featuredClasses = (await getCollection('videos'))
  .filter((v) => v.data.poses_featured.includes(d.slug))
  .sort(
    (a, b) =>
      Number(b.data.enriched) - Number(a.data.enriched) ||
      (b.data.watch_hours ?? 0) - (a.data.watch_hours ?? 0),
  )
  .slice(0, 3);

const titleCase = (s: string) =>
  s.replace(/\b\w/g, (c) => c.toUpperCase());
const humanise = (slug: string) =>
  titleCase(slug.replace(/-/g, ' '));

// --- schema.org HowTo, built from cues, hold_time and props ------------------
// totalTime = the largest minute figure found in hold_time, as ISO-8601 (PT#M).
const minuteFigures = (d.hold_time.match(/\d+/g) ?? []).map(Number);
const totalMinutes = minuteFigures.length ? Math.max(...minuteFigures) : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: d.name_en,
  description: d.seo_description,
  ...(totalMinutes ? { totalTime: `PT${totalMinutes}M` } : {}),
  ...(d.props.length
    ? { supply: d.props.map((name) => ({ '@type': 'HowToSupply', name })) }
    : {}),
  step: d.cues.map((text) => ({ '@type': 'HowToStep', text })),
};

const hasVideo = Boolean(d.youtube_video_id && d.youtube_video_id.trim());
const eyebrow = `Yin Yoga · ${titleCase(d.accessibility)}`;

// Canonical pin (og:image + Pinterest media): the split variant when the pose has a
// real photo (full subject, natural aspect), else a text-led arch pin. Per the handoff,
// meta NEVER reveals the hold time — "Long hold" + the areas worked; the click reveals it.
const posePhoto = d.images[0] && !d.images[0].includes('pose-placeholder') ? d.images[0] : null;
const poseMeta = `Long hold · ${d.target_areas.slice(0, 2).join(' & ')}`;
const journalPin = journalPinUrl(Astro.site, {
  variant: posePhoto ? 'split' : 'arch',
  title: d.name_en,
  eyebrow: 'Pose library',
  meta: poseMeta,
  excerpt: d.benefits[0],
  photo: posePhoto,
});

// FAQPage schema — rendered alongside the HowTo when the pose has FAQs.
const faqLd = d.faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: d.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

// Default target for the on-page hold timer (all poses carry hold_seconds; 180s is a safe fallback).
const holdSeconds = d.hold_seconds ?? 180;

// Save-to-Pinterest uses the same canonical pin, linking back to this pose page.
const poseUrl = new URL(`/poses/${d.slug}/`, Astro.site).href;
const poseSave = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(poseUrl)}&media=${encodeURIComponent(journalPin)}&description=${encodeURIComponent(d.seo_description)}`;
---

<BaseLayout
  title={d.seo_title}
  description={d.seo_description}
  ogTitle={d.name_en}
  ogDescription={d.seo_description}
  ogType="article"
  image={journalPin}
  jsonLd={faqLd ? [jsonLd, faqLd] : jsonLd}
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{d.name_en}</h1>

      <div class="hold" aria-label="Recommended hold time">
        <span class="hold-eyebrow">Hold</span>
        <p class="hold-time">{d.hold_time}</p>
      </div>
    </header>

    {/* Single reference photo, directly under the hero. Poses still awaiting their own
        photo use an on-brand illustration placeholder with a gentle "coming soon" note. */}
    {
      d.images.length > 0 && (() => {
        const pending = d.images[0].includes('pose-placeholder');
        return (
          <figure class={`pose-photo${pending ? ' is-placeholder' : ''}`}>
            <img
              src={d.images[0]}
              alt={pending ? `${d.name_en} yin yoga pose illustration` : `${d.name_en} yin yoga pose`}
              loading="lazy"
              onerror="this.closest('.pose-photo').remove()"
            />
            {pending && <figcaption>Photo coming soon</figcaption>}
          </figure>
        );
      })()
    }

    {poseSave && (
      <div class="pose-share">
        <a class="pose-pin-btn" href={poseSave} target="_blank" rel="noopener noreferrer" aria-label="Save this pose to Pinterest">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C24.007 5.367 18.641.001 12.017.001z"/></svg>
          Save this pose
        </a>
      </div>
    )}

    {/* Hold timer — set your length and let the shape do the work. */}
    <section class="timer-section">
      <h2>Time your hold</h2>
      <PoseTimer seconds={holdSeconds} holdLabel={d.hold_time} />
    </section>

    {/* Follow-along video — separate section, only when a video id is set. */}
    {
      hasVideo && (
        <section class="follow-along">
          <h2>Follow along</h2>
          <div class="video-embed">
            <iframe
              src={`https://www.youtube.com/embed/${d.youtube_video_id}`}
              title={`${d.name_en} — practice video`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </section>
      )
    }

    {
      featuredRoutines.length > 0 && (
        <section class="featured-in">
          <h2>Routines featuring this pose</h2>
          {featuredRoutines.map((r) => (
            <a href={`/routines/${r.data.slug}`}>
              {r.data.title}
              <span>{r.data.minutes} min · {r.data.summary}</span>
            </a>
          ))}
        </section>
      )
    }

    <section>
      <h2>How to do it</h2>
      <ol class="cues">
        {d.cues.map((cue) => <li>{cue}</li>)}
      </ol>
    </section>

    <section>
      <h2>Why practise it</h2>
      <ul class="plain">
        {d.benefits.map((b) => <li>{b}</li>)}
      </ul>
    </section>

    {
      (d.transitions_in.length > 0 || d.transitions_out.length > 0) && (
        <section>
          <h2>Coming in &amp; out</h2>
          <div class="transitions">
            {d.transitions_in.length > 0 && (
              <div>
                <h3>Into the pose</h3>
                <ul class="plain">
                  {d.transitions_in.map((t) => <li>{t}</li>)}
                </ul>
              </div>
            )}
            {d.transitions_out.length > 0 && (
              <div>
                <h3>Out of the pose</h3>
                <ul class="plain">
                  {d.transitions_out.map((t) => <li>{t}</li>)}
                </ul>
              </div>
            )}
          </div>
        </section>
      )
    }

    {
      d.cautions.length > 0 && (
        <section>
          <div class="cautions">
            <h2>Take care</h2>
            <ul class="plain">
              {d.cautions.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        </section>
      )
    }

    <section>
      <h2>At a glance</h2>
      <dl class="glance">
        <div class="row"><dt>Hold</dt><dd>{d.hold_time}</dd></div>
        <div class="row"><dt>Level</dt><dd>{titleCase(d.accessibility)}</dd></div>
        <div class="row">
          <dt>Target areas</dt>
          <dd>{d.target_areas.map((t) => <span class="tag">{t}</span>)}</dd>
        </div>
        {
          d.meridians.length > 0 && (
            <div class="row">
              <dt>Meridians</dt>
              <dd>{d.meridians.map((m) => <span class="tag">{m}</span>)}</dd>
            </div>
          )
        }
        {
          d.props.length > 0 && (
            <div class="row">
              <dt>Props</dt>
              <dd>{d.props.map((p) => <span class="tag">{p}</span>)}</dd>
            </div>
          )
        }
        {
          d.counterposes.length > 0 && (
            <div class="row">
              <dt>Counterpose</dt>
              <dd>{d.counterposes.join(' · ')}</dd>
            </div>
          )
        }
      </dl>
    </section>

    {
      d.faq.length > 0 && (
        <section class="faq-section">
          <h2>Common questions</h2>
          {d.faq.map((f) => (
            <details class="faq">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </section>
      )
    }

    <Cta
      source="pose"
      eyebrow="Put it all together"
      heading="When you want the whole practice"
      body={`${d.name_en} is one shape among many. When you'd like to put a whole sequence together into one long, slow practice, pop your email in and I'll send you my free two-hour Yin, restorative and Yoga Nidra retreat. Yours to keep.`}
    />

    {
      d.related_poses.length > 0 && (
        <section class="related">
          <h2>Related poses</h2>
          {d.related_poses.map((slug) => {
            const rel = bySlug.get(slug);
            return (
              <a href={`/poses/${slug}`}>
                {rel ? rel.name_en : humanise(slug)}
                {rel && <span>{rel.seo_description}</span>}
              </a>
            );
          })}
        </section>
      )
    }

    {
      featuredClasses.length > 0 && (
        <section class="featured-in">
          <h2>Classes featuring this pose</h2>
          {featuredClasses.map((v) => (
            <a href={`/videos/${v.data.slug}`}>
              {videoHeadline(v.data)}
              <span>{v.data.display_length?.trim() || `${v.data.length_minutes} min`} · {v.data.summary}</span>
            </a>
          ))}
        </section>
      )
    }

    <footer>
      <p class="src">
        Content grounded in Bernie Clark, <em>The Complete Guide to Yin Yoga</em>.
        Original copy. Contraindications to be verified before publishing as advice.
      </p>
    </footer>
  </div>
</BaseLayout>
