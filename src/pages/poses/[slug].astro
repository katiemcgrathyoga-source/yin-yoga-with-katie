---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { splitTitle } from '../../lib/title';

/**
 * One reusable template for every pose. `getStaticPaths` reads the whole
 * collection and emits a static page per file, keyed by each pose's `slug`.
 * Add a Markdown file to src/content/poses/ and a new page appears — no code.
 */
export async function getStaticPaths() {
  const poses = await getCollection('poses');
  return poses.map((pose) => ({
    params: { slug: pose.data.slug },
    props: { pose, poses },
  }));
}

const { pose, poses } = Astro.props;
const d = pose.data;

// Lookup of slug -> pose data, so related-pose links can show real names
// when the related pose already exists in the collection.
const bySlug = new Map(poses.map((p) => [p.data.slug, p.data]));

// Reverse of the video→pose link: every class whose `poses_featured` includes
// this pose, newest first. This is the pose's connection back into the library.
const featuredIn = (await getCollection('videos'))
  .filter((v) => v.data.poses_featured.includes(d.slug))
  .sort((a, b) => (b.data.published?.getTime() ?? 0) - (a.data.published?.getTime() ?? 0));

const titleCase = (s: string) =>
  s.replace(/\b\w/g, (c) => c.toUpperCase());
const humanise = (slug: string) =>
  titleCase(slug.replace(/-/g, ' '));

// --- Hold-time marker (the signature element) -------------------------------
// Split "1–5 minutes per side (Full Swan 1–3 min, ...)" into a big number, a
// unit, and a caption — entirely from the data, so it works for any pose.
const holdMatch = d.hold_time.match(/^\s*([\d.–—\-\s]+?)\s*(minutes?|mins?|seconds?|secs?)\b\s*(.*)$/i);
const orbBig = holdMatch ? holdMatch[1].trim() : d.hold_time;
const orbUnit = holdMatch ? holdMatch[2].toLowerCase().replace(/s$/, '') + 's' : '';
const orbCaption = holdMatch
  ? holdMatch[3].replace(/\(/g, '· ').replace(/\)/g, '').trim()
  : '';

// --- schema.org HowTo, built from cues, hold_time and props ------------------
// totalTime = the largest minute figure found in hold_time, as ISO-8601 (PT#M).
const minuteFigures = (d.hold_time.match(/\d+/g) ?? []).map(Number);
const totalMinutes = minuteFigures.length ? Math.max(...minuteFigures) : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `${d.name_en} (${d.also_known_as[0] ?? d.name_en})`,
  description: d.seo_description,
  ...(totalMinutes ? { totalTime: `PT${totalMinutes}M` } : {}),
  ...(d.props.length
    ? { supply: d.props.map((name) => ({ '@type': 'HowToSupply', name })) }
    : {}),
  step: d.cues.map((text) => ({ '@type': 'HowToStep', text })),
};

const hasVideo = Boolean(d.youtube_video_id && d.youtube_video_id.trim());
const eyebrow = `Yin Yoga · ${titleCase(d.accessibility)}`;
---

<BaseLayout
  title={d.seo_title}
  description={d.seo_description}
  ogTitle={d.name_en}
  ogDescription={d.seo_description}
  ogType="article"
  image={d.images[0]}
  jsonLd={jsonLd}
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{d.name_en}</h1>
      <p class="alt">{d.name_sanskrit}</p>
      {
        d.also_known_as.length > 0 && (
          <p class="aka">Also known as {d.also_known_as.join(' · ')}</p>
        )
      }

      <div class="breath" aria-label="Recommended hold time">
        <div class="orb">
          <span class="t">{orbBig}{orbUnit && <small>{orbUnit}</small>}</span>
        </div>
        {orbCaption && <span class="cap">{orbCaption}</span>}
      </div>

    </header>

    {/* Still photo reference — always shown, prominent, directly under the hero. */}
    {
      d.images.length > 0 && (
        <div class="photo-block">
          <div class="gallery">
            {d.images.map((src, i) => (
              <figure>
                <img
                  src={src}
                  alt={`${d.name_en} — figure ${i + 1}`}
                  loading="lazy"
                  onerror="this.closest('figure').remove()"
                />
              </figure>
            ))}
          </div>
        </div>
      )
    }

    {/* Follow-along video — separate section, only when a video id is set. */}
    {
      hasVideo && (
        <section class="follow-along">
          <h2>Follow along</h2>
          <div class="video-embed">
            <iframe
              src={`https://www.youtube.com/embed/${d.youtube_video_id}`}
              title={`${d.name_en} — practice video`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </section>
      )
    }

    {
      featuredIn.length > 0 && (
        <section class="featured-in">
          <h2>Classes featuring this pose</h2>
          {featuredIn.map((v) => (
            <a href={`/videos/${v.data.slug}`}>
              {splitTitle(v.data.title).headline}
              <span>{v.data.display_length?.trim() || `${v.data.length_minutes} min`} · {v.data.summary}</span>
            </a>
          ))}
        </section>
      )
    }

    <section>
      <h2>How to do it</h2>
      <ol class="cues">
        {d.cues.map((cue) => <li>{cue}</li>)}
      </ol>
    </section>

    <section>
      <h2>Why practise it</h2>
      <ul class="plain">
        {d.benefits.map((b) => <li>{b}</li>)}
      </ul>
    </section>

    {
      (d.transitions_in.length > 0 || d.transitions_out.length > 0) && (
        <section>
          <h2>Coming in &amp; out</h2>
          <div class="transitions">
            {d.transitions_in.length > 0 && (
              <div>
                <h3>Into the pose</h3>
                <ul class="plain">
                  {d.transitions_in.map((t) => <li>{t}</li>)}
                </ul>
              </div>
            )}
            {d.transitions_out.length > 0 && (
              <div>
                <h3>Out of the pose</h3>
                <ul class="plain">
                  {d.transitions_out.map((t) => <li>{t}</li>)}
                </ul>
              </div>
            )}
          </div>
        </section>
      )
    }

    {
      d.cautions.length > 0 && (
        <section>
          <div class="cautions">
            <h2>Take care</h2>
            <ul class="plain">
              {d.cautions.map((c) => <li>{c}</li>)}
            </ul>
          </div>
        </section>
      )
    }

    <section>
      <h2>At a glance</h2>
      <dl class="glance">
        <div class="row"><dt>Hold</dt><dd>{d.hold_time}</dd></div>
        <div class="row"><dt>Level</dt><dd>{titleCase(d.accessibility)}</dd></div>
        <div class="row">
          <dt>Target areas</dt>
          <dd>{d.target_areas.map((t) => <span class="tag">{t}</span>)}</dd>
        </div>
        {
          d.meridians.length > 0 && (
            <div class="row">
              <dt>Meridians</dt>
              <dd>{d.meridians.map((m) => <span class="tag">{m}</span>)}</dd>
            </div>
          )
        }
        {
          d.props.length > 0 && (
            <div class="row">
              <dt>Props</dt>
              <dd>{d.props.map((p) => <span class="tag">{p}</span>)}</dd>
            </div>
          )
        }
        {
          d.counterposes.length > 0 && (
            <div class="row">
              <dt>Counterpose</dt>
              <dd>{d.counterposes.join(' · ')}</dd>
            </div>
          )
        }
      </dl>
    </section>

    <!-- Email capture — non-functional placeholder for Phase 1.
         The email provider wires in here in a later phase. -->
    <div class="cta">
      <p class="eyebrow">Free download</p>
      <h2>Bedtime Yin, in your inbox</h2>
      <p>A printable wind-down sequence to settle the nervous system before sleep. One email, then the PDF is yours.</p>
      <form class="form" onsubmit="return false;" aria-label="Email capture (placeholder)">
        <input type="email" placeholder="you@email.com" aria-label="Email address" required />
        <button type="submit">Send it to me</button>
      </form>
      <p class="note">Placeholder — email provider wires in here in a later phase.</p>
    </div>

    {
      d.related_poses.length > 0 && (
        <section class="related">
          <h2>Related poses</h2>
          {d.related_poses.map((slug) => {
            const rel = bySlug.get(slug);
            return (
              <a href={`/poses/${slug}`}>
                {rel ? rel.name_en : humanise(slug)}
                {rel && <span>{rel.seo_description}</span>}
              </a>
            );
          })}
        </section>
      )
    }

    <footer>
      <p class="src">
        Content grounded in Bernie Clark, <em>The Complete Guide to Yin Yoga</em>.
        Original copy. Contraindications to be verified before publishing as advice.
      </p>
    </footer>
  </div>
</BaseLayout>
