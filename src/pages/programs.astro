---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROGRAMS, resolveProgramClasses, unitPlural } from '../data/programs';
import { videoHeadline, lenLabel } from '../lib/video';

// Each program's class list is resolved live from the library.
const videos = await getCollection('videos');
const resolved = PROGRAMS.map((def) => ({ def, classes: resolveProgramClasses(def, videos) }));

// Spotlight the first program (the "if you're new, start here" path); the rest
// sit below as a quiet index.
const featured = resolved[0];
const others = resolved.slice(1);
const featuredFirst = featured.classes[0]?.data;
---

<BaseLayout
  title="Programs — Yin Yoga with Katie"
  description="Free, guided Yin Yoga programs — follow a plan instead of choosing a class each day. Wind down for sleep, get flexible, free your hips, or calm a busy mind."
>
  <div class="wrap">
    <header class="hero pg-hero">
      <p class="eyebrow">programs</p>
      <h1>A few classes, in the right order</h1>
    </header>
  </div>

  <section class="pg-band">
    <div class="pg-inner">
      <div class="pg-featured">
        <div class="pg-featured-copy">
          <span class="pg-badge">if you're new, start here</span>
          <h2>{featured.def.title}</h2>
          <p class="pg-promise">{featured.def.outcome}</p>
          <p class="pg-blurb">{featured.def.blurb}</p>
          <div class="pg-featured-actions">
            {featuredFirst && (
              <a class="pg-begin" href={`/videos/${featuredFirst.slug}`}>Begin with class one →</a>
            )}
            <a class="pg-cal" href={`/calendar?program=${featured.def.slug}`}>Add to my calendar</a>
          </div>
        </div>
        <div class="pg-classlist">
          <div class="pg-classlist-head">what's inside · {unitPlural(featured.def, featured.classes.length)}</div>
          {featured.classes.map((c, i) => (
            <a class="pg-class-row" href={`/videos/${c.data.slug}`}>
              <span class="pg-class-n">{i + 1}</span>
              <span class="pg-class-title">{videoHeadline(c.data)}</span>
              <span class="pg-class-len">{lenLabel(c.data)}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="pg-others">
        <p class="pg-others-label">the other paths</p>
        {others.map(({ def, classes }) => (
          <a class="pg-other-row" href={`/programs/${def.slug}`}>
            <span class="pg-other-name">
              <span class="pg-other-title">{def.title}</span>
              <span class="pg-other-meta">{unitPlural(def, classes.length)} · {def.tagline}</span>
            </span>
            <span class="pg-other-desc"><strong>{def.outcome}</strong> {def.blurb}</span>
            <span class="pg-other-go">See the path →</span>
          </a>
        ))}
        <p class="pg-foot">All programs are free, no login — and every class in them also lives in <a href="/">the library</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
