---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoutinePlayer from '../../components/RoutinePlayer.astro';
import Cta from '../../components/Cta.astro';

export async function getStaticPaths() {
  const routines = await getCollection('routines');
  const poses = await getCollection('poses');
  return routines.map((routine) => ({
    params: { slug: routine.data.slug },
    props: { routine, poses, routines },
  }));
}

const { routine, poses, routines } = Astro.props;
const d = routine.data;

const titleCase = (s: string) => s.replace(/\b\w/g, (c) => c.toUpperCase());
const humanise = (slug: string) => titleCase(slug.replace(/-/g, ' '));
const bySlug = new Map(poses.map((p) => [p.data.slug, p.data]));

// Expand each step into the flat list of holds the player runs (two-sided poses
// become Side 1 / Side 2), resolving pose slug → name, photo and cue.
type Hold = { name: string; slug: string; img: string; seconds: number; note: string; sideLabel?: string };
const holds: Hold[] = d.steps.flatMap((s) => {
  const p = bySlug.get(s.pose);
  const base = {
    name: p?.name_en ?? humanise(s.pose),
    slug: s.pose,
    img: p?.images?.[0] ?? '',
    seconds: s.seconds,
    note: s.note ?? p?.cues?.[0] ?? '',
  };
  return s.sides === 2
    ? [{ ...base, sideLabel: 'Side 1' }, { ...base, sideLabel: 'Side 2' }]
    : [base];
});

const totalSeconds = holds.reduce((n, h) => n + h.seconds, 0);
const totalMin = Math.round(totalSeconds / 60);
const poseCount = d.steps.length;

// Social/OG image = a branded card generated by the serverless OG function, so
// shared links show the Yin Yoga with Katie card (matches the completion badge).
const ogImage = new URL('/og/card.png', Astro.site);
ogImage.searchParams.set('t', d.title);
ogImage.searchParams.set('s', `A ${totalMin}-minute Yin routine`);
// The hero pose photo is still used for Pinterest's pinned media in the player.
const heroImg = (d.hero_pose && bySlug.get(d.hero_pose)?.images?.[0]) || holds[0]?.img;

// Other routines to suggest at the foot of the page.
const others = routines.filter((r) => r.data.slug !== d.slug).slice(0, 3);

// Save-to-Pinterest: a numbered-sequence pin of this routine (first five poses).
const routineUrl = new URL(`/routines/${d.slug}/`, Astro.site).href;
const fmtHold = (secs: number, sides: number) => `${Math.max(1, Math.round(secs / 60))} min${sides === 2 ? ' each side' : ''}`;
const routinePinItems = d.steps.slice(0, 5).map((s) => {
  const p = bySlug.get(s.pose);
  const photo = p?.images?.[0] && !p.images[0].includes('pose-placeholder') ? p.images[0] : undefined;
  return { name: p?.name_en ?? humanise(s.pose), note: fmtHold(s.seconds, s.sides), ...(photo ? { img: photo } : {}) };
});
const routinePinImg = new URL('/pin/card.png', Astro.site);
routinePinImg.searchParams.set('tpl', 'numbered');
routinePinImg.searchParams.set('t', d.title);
routinePinImg.searchParams.set('s', `${d.minutes}-minute yin routine`);
routinePinImg.searchParams.set('items', JSON.stringify(routinePinItems));
const routineSave = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(routineUrl)}&media=${encodeURIComponent(routinePinImg.href)}&description=${encodeURIComponent(d.summary)}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: d.title,
  description: d.seo_description,
  totalTime: `PT${totalMin}M`,
  step: holds.map((h, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: `${h.name}${h.sideLabel ? ' · ' + h.sideLabel : ''}`,
    text: h.note || `Hold ${h.name} for ${Math.round(h.seconds / 60) || 1} minute(s).`,
    ...(h.img ? { image: new URL(h.img, Astro.site).href } : {}),
  })),
};

const faqLd = d.faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: d.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---

<BaseLayout
  title={d.seo_title}
  description={d.seo_description}
  ogTitle={d.title}
  ogDescription={d.seo_description}
  ogType="article"
  image={ogImage.href}
  jsonLd={faqLd ? [jsonLd, faqLd] : jsonLd}
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">Yin Routine · {titleCase(d.level.replace('-', ' '))}</p>
      <h1>{d.title}</h1>
      {d.tagline && <p class="routine-tagline">{d.tagline}</p>}
      <p class="routine-facts">
        <span>{totalMin} min</span> · <span>{poseCount} poses</span>
        {d.props.length > 0 ? <> · <span>{d.props.join(', ')}</span></> : <> · <span>no props</span></>}
      </p>
    </header>

    <section class="routine-intro">
      <p>{d.intro}</p>
    </section>

    <div class="pose-share">
      <a class="pose-pin-btn" href={routineSave} target="_blank" rel="noopener noreferrer" aria-label="Save this routine to Pinterest">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C24.007 5.367 18.641.001 12.017.001z"/></svg>
        Save this routine
      </a>
    </div>

    {/* The follow-along practice player. */}
    <section class="player-section" aria-label="Practice player">
      <RoutinePlayer
        title={d.title}
        holds={holds}
        shareUrl={new URL(`/routines/${d.slug}`, Astro.site).href}
        imageUrl={heroImg ? new URL(heroImg, Astro.site).href : undefined}
      />
      <p class="player-help">
        Press play and follow along — each hold is timed, with a gentle chime and a
        moment to ease out before the next pose. Use <strong>Skip</strong> or
        <strong>Prev</strong> to move at your own pace.
      </p>
    </section>

    <section class="routine-list">
      <h2>What's in this routine</h2>
      <ol class="seq">
        {
          d.steps.map((s) => {
            const p = bySlug.get(s.pose);
            const name = p?.name_en ?? humanise(s.pose);
            const mins = s.seconds >= 60 ? `${Math.round(s.seconds / 60)} min` : `${s.seconds}s`;
            return (
              <li>
                <div class="seq-main">
                  {p ? <a href={`/poses/${s.pose}`}>{name}</a> : <span>{name}</span>}
                  {s.note && <span class="seq-note">{s.note}</span>}
                </div>
                <span class="seq-hold">
                  {mins}
                  {s.sides === 2 ? ' each side' : ''}
                </span>
              </li>
            );
          })
        }
      </ol>
    </section>

    {
      d.faq.length > 0 && (
        <section class="faq-section">
          <h2>Common questions</h2>
          {d.faq.map((f) => (
            <details class="faq">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </section>
      )
    }

    <Cta />

    {
      others.length > 0 && (
        <section class="related">
          <h2>More routines</h2>
          {others.map((r) => (
            <a href={`/routines/${r.data.slug}`}>
              {r.data.title}
              <span>{r.data.minutes} min · {r.data.summary}</span>
            </a>
          ))}
        </section>
      )
    }

    <footer>
      <p class="src">
        Sequences and cues are original, grounded in Bernie Clark,
        <em>The Complete Guide to Yin Yoga</em>. Move gently and check the
        cautions on each pose page before practising.
      </p>
    </footer>
  </div>
</BaseLayout>
