---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Yin Yoga Routines — Follow-Along Practices with a Timer"
  description="Short, self-guided Yin Yoga routines with a built-in hold timer — no video to watch. Browse curated sequences by time, area and mood, or build your own. Free."
>
  <div class="wrap fork-wrap">
    <header class="hero fork-hero">
      <p class="eyebrow">routines</p>
      <h1>How would you like to practise today?</h1>
      <p class="fork-note">both are free — self-guided, timed, quiet</p>
    </header>

    <div class="fork-cards">
      <a class="fork-card fork-prebuilt" href="/routines/all" data-choice="prebuilt">
        <span class="fork-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
        </span>
        <span class="fork-title">Pre-built routines</span>
        <span class="fork-desc">Curated sequences, ready to begin — by time, by area, by mood.</span>
        <span class="fork-go">Browse the routines →</span>
      </a>
      <a class="fork-card fork-build" href="/routines/builder" data-choice="build">
        <span class="fork-ico" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h4l2-7 3 14 2-7h3"/></svg>
        </span>
        <span class="fork-title">Build your own</span>
        <span class="fork-desc">Tell Katie what your body needs — a sequence is composed for you.</span>
        <span class="fork-go">Start building →</span>
      </a>
    </div>
  </div>

  <script>
    // Remember the choice so returning visitors skip the fork. `?fork` forces it.
    const KEY = 'yin-routine-choice';
    const params = new URLSearchParams(location.search);
    if (!params.has('fork')) {
      try {
        const c = localStorage.getItem(KEY);
        if (c === 'prebuilt') location.replace('/routines/all');
        else if (c === 'build') location.replace('/routines/builder');
      } catch (e) {}
    }
    document.querySelectorAll<HTMLAnchorElement>('[data-choice]').forEach((a) =>
      a.addEventListener('click', () => { try { localStorage.setItem(KEY, a.dataset.choice!); } catch (e) {} }),
    );
  </script>
</BaseLayout>
