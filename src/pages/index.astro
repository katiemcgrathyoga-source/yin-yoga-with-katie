---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { derivedThumb, lenLabel, byRecencyThenWatch, videoHeadline } from '../lib/video';

// Recent classes lead (current thumbnails / branding), then older ones — each
// tier by watch-hours. New video files appear here automatically.
const videos = (await getCollection('videos')).sort((a, b) => byRecencyThenWatch(a.data, b.data));

// --- Length buckets — fixed taxonomy; the top bucket catches 90+ so nothing
//     ever falls through. Only buckets with at least one class are shown. ------
const BUCKETS = [
  { key: 'under-20', label: 'Under 20 min', test: (m: number) => m < 20 },
  { key: '20-40', label: '20–40 min', test: (m: number) => m >= 20 && m < 40 },
  { key: '40-60', label: '40–60 min', test: (m: number) => m >= 40 && m < 60 },
  { key: '60-90', label: '60–90 min', test: (m: number) => m >= 60 },
];
const bucketOf = (m: number) => BUCKETS.find((b) => b.test(m))!.key;

// --- Filter facets, built from the classes actually present -------------------
type V = (typeof videos)[number];

// Intent — a FIXED, curated taxonomy so the filter row stays clean no matter what
// intent_tags future enrichments add. Raw tags map into these buckets; any tag not
// listed here (e.g. "beginner", "back", "hips-lower-back") is simply not surfaced as
// an Intent chip — it's still stored on the video and used elsewhere. To add/rename a
// filter, edit THIS list only.
const INTENT_BUCKETS = [
  { key: 'sleep', label: 'Sleep', tags: ['sleep'] },
  { key: 'calm', label: 'Stress & calm', tags: ['nervous-system', 'stress'] },
  { key: 'digestion', label: 'Digestion', tags: ['digestion'] },
  { key: 'energy', label: 'Energy', tags: ['energy'] },
  { key: 'flexibility', label: 'Flexibility', tags: ['flexibility'] },
  { key: 'full-body', label: 'Full body', tags: ['full-body'] },
];
const intentKeys = (v: V) =>
  INTENT_BUCKETS.filter((b) => b.tags.some((t) => v.data.intent_tags.includes(t))).map((b) => b.key);
const presentIntents = INTENT_BUCKETS.filter((b) => videos.some((v) => intentKeys(v).includes(b.key)));
// Small tile badges show only the genuinely *distinguishing* intents — not the
// near-universal calm / flexibility / full-body — so tiles stay uncluttered and a
// badge actually means something. Capped at two.
const BADGE_INTENTS = new Set(['sleep', 'digestion', 'energy']);
const intentBadges = (v: V) => {
  const keys = intentKeys(v).filter((k) => BADGE_INTENTS.has(k)).slice(0, 2);
  return keys.map((k) => INTENT_BUCKETS.find((b) => b.key === k)!.label);
};

// Body area → a few curated buckets; each raw area maps into one.
const AREA_BUCKETS = [
  { key: 'hips', label: 'Hips', match: (a: string) => /hip|groin/.test(a) },
  { key: 'lower-back', label: 'Lower back', match: (a: string) => /lower back|low back|sacrum/.test(a) },
  { key: 'shoulders', label: 'Shoulders', match: (a: string) => /shoulder|neck|upper back|chest/.test(a) },
  { key: 'spine', label: 'Spine', match: (a: string) => /\bspine\b/.test(a) },
  { key: 'legs', label: 'Legs', match: (a: string) => /hamstring|quad|\bleg|ankle|feet|knee/.test(a) },
];
const areaBuckets = (v: V) => {
  const set = new Set<string>();
  for (const raw of v.data.body_areas) {
    const a = raw.toLowerCase();
    for (const b of AREA_BUCKETS) if (b.match(a)) set.add(b.key);
  }
  if (v.data.intent_tags.includes('hips-lower-back')) { set.add('hips'); set.add('lower-back'); }
  return [...set];
};
const presentAreas = AREA_BUCKETS.filter((b) => videos.some((v) => areaBuckets(v).includes(b.key)));

// Style — silent · no props · members only.
const styleTags = (v: V) => {
  const s: string[] = [];
  if (/silent|minimal cues|no extra talking|no.?talking/i.test(v.data.title)) s.push('silent');
  if (v.data.props.length === 0 || v.data.props.every((p) => /^none$/i.test(p)) || /no.?props|without props|prop.?free/i.test(v.data.title)) s.push('no-props');
  if (v.data.membership) s.push('members');
  return s;
};
const STYLE_OPTS = [
  { key: 'silent', label: 'Silent' },
  { key: 'no-props', label: 'No props' },
  { key: 'members', label: 'Members only' },
];
const presentStyles = STYLE_OPTS.filter((o) => videos.some((v) => styleTags(v).includes(o.key)));

const presentBuckets = BUCKETS.filter((b) => videos.some((v) => bucketOf(v.data.length_minutes) === b.key));

// Branded OG card for link previews of the homepage.
const ogImage = new URL('/og/card.png', Astro.site);
ogImage.searchParams.set('t', 'Free Yin Yoga Classes');
ogImage.searchParams.set('s', 'Full-length practices to follow along');
---

<BaseLayout
  title="Yin Yoga with Katie — the video library"
  description="A growing library of full-length Yin Yoga classes you can follow on YouTube. Filter by intent, length and body area to find the right practice for today."
  image={ogImage.href}
>
  <div class="wrap">
    <header class="hero">
      <p class="eyebrow">Yin Yoga with Katie</p>
      <h1>The Library</h1>
      <p class="alt">full-length classes to settle into — filter for exactly what your body needs today</p>
    </header>

    <p class="page-intro">
      Every one of my Yin Yoga classes, in one place. Yin is slow, floor-based yoga —
      long, gently-held stretches that ease tension, calm the mind and build flexibility
      over time. Filter by how long you have, the part of the body you want to work, or
      how you'd like to feel, and press play. New here? Start with a beginner class or a
      short <a href="/routines">follow-along routine</a>.
    </p>

    <section>
      <div class="filters" id="filters">
        <div class="facet">
          <span class="facet-label">Intent</span>
          <div class="chips">
            {presentIntents.map((b) => (
              <button type="button" class="chip" data-facet="intent" data-value={b.key} aria-pressed="false">{b.label}</button>
            ))}
          </div>
        </div>

        {presentBuckets.length > 0 && (
          <div class="facet">
            <span class="facet-label">Length</span>
            <div class="chips">
              {presentBuckets.map((b) => (
                <button type="button" class="chip" data-facet="length" data-value={b.key} aria-pressed="false">{b.label}</button>
              ))}
            </div>
          </div>
        )}

        <div class="facet">
          <span class="facet-label">Body area</span>
          <div class="chips">
            {presentAreas.map((b) => (
              <button type="button" class="chip" data-facet="area" data-value={b.key} aria-pressed="false">{b.label}</button>
            ))}
          </div>
        </div>

        {presentStyles.length > 0 && (
          <div class="facet">
            <span class="facet-label">Style</span>
            <div class="chips">
              {presentStyles.map((o) => (
                <button type="button" class="chip" data-facet="style" data-value={o.key} aria-pressed="false">{o.label}</button>
              ))}
            </div>
          </div>
        )}

        <div class="filter-meta">
          <button type="button" class="chip chip-clear" id="clear-filters" hidden>Clear filters</button>
          <span class="count" id="result-count" aria-live="polite"></span>
        </div>
      </div>

      <div class="tiles" id="tiles">
        {videos.map((v) => (
          <a
            class="tile"
            href={`/videos/${v.data.slug}`}
            data-tile
            data-intent={intentKeys(v).join('|')}
            data-area={areaBuckets(v).join('|')}
            data-style={styleTags(v).join('|')}
            data-length={bucketOf(v.data.length_minutes)}
          >
            <div class="tile-thumb">
              <img class="tile-img" src={derivedThumb(v.data)} alt={v.data.title} loading="lazy" width="480" height="270" />
              <span class="tile-len">{lenLabel(v.data)}</span>
              {v.data.membership && <span class="tile-members">Members</span>}
            </div>
            <div class="tile-body">
              <h3 class="tile-name">{videoHeadline(v.data)}</h3>
              <div class="tile-tags">
                {intentBadges(v).map((label) => <span class="tag tag-intent">{label}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>

      <p class="empty" id="empty" hidden>No classes match those filters yet.</p>
      <div class="show-more">
        <button type="button" class="btn btn-secondary" id="show-all" hidden></button>
      </div>
    </section>

    <footer>
      <p class="src">New classes are added by dropping a Markdown file into the library.</p>
    </footer>
  </div>
</BaseLayout>

<script>
  // Client-side faceted filtering — no framework. OR within a facet, AND across.
  const tiles = Array.from(document.querySelectorAll<HTMLElement>('[data-tile]'));
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip[data-facet]'));
  const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement | null;
  const countEl = document.getElementById('result-count');
  const emptyEl = document.getElementById('empty');

  const showAllBtn = document.getElementById('show-all') as HTMLButtonElement | null;
  // Unfiltered, only the first LIMIT classes show, so the homepage isn't a wall
  // of hundreds of tiles. Filtering (or "show all") reveals everything.
  const LIMIT = 36;
  let showAll = false;

  const active: Record<string, Set<string>> = {
    intent: new Set(),
    length: new Set(),
    area: new Set(),
    style: new Set(),
  };

  const split = (v: string | undefined) => (v ? v.split('|').filter(Boolean) : []);

  function apply() {
    const anyActive =
      active.intent.size + active.length.size + active.area.size + active.style.size > 0;
    const capped = !anyActive && !showAll;
    let matched = 0;
    let shown = 0;
    for (const tile of tiles) {
      const intents = split(tile.dataset.intent);
      const areas = split(tile.dataset.area);
      const styles = split(tile.dataset.style);
      const length = tile.dataset.length ?? '';

      const okIntent = active.intent.size === 0 || intents.some((v) => active.intent.has(v));
      const okLength = active.length.size === 0 || active.length.has(length);
      const okArea = active.area.size === 0 || areas.some((v) => active.area.has(v));
      const okStyle = active.style.size === 0 || styles.some((v) => active.style.has(v));

      const match = okIntent && okLength && okArea && okStyle;
      if (match) matched++;
      const show = match && (!capped || shown < LIMIT);
      tile.hidden = !show;
      if (show) shown++;
    }

    if (clearBtn) clearBtn.hidden = !anyActive;
    if (emptyEl) emptyEl.hidden = matched > 0;
    if (countEl) {
      countEl.textContent = anyActive
        ? `${matched} of ${tiles.length} ${tiles.length === 1 ? 'class' : 'classes'}`
        : '';
    }
    if (showAllBtn) {
      const hiddenCount = tiles.length - LIMIT;
      showAllBtn.hidden = !(capped && hiddenCount > 0);
      showAllBtn.textContent = `Show all ${tiles.length} classes`;
    }
  }

  showAllBtn?.addEventListener('click', () => {
    showAll = true;
    apply();
  });

  for (const chip of chips) {
    chip.addEventListener('click', () => {
      const facet = chip.dataset.facet!;
      const value = chip.dataset.value!;
      const set = active[facet];
      if (set.has(value)) {
        set.delete(value);
        chip.setAttribute('aria-pressed', 'false');
        chip.classList.remove('active');
      } else {
        set.add(value);
        chip.setAttribute('aria-pressed', 'true');
        chip.classList.add('active');
      }
      apply();
    });
  }

  clearBtn?.addEventListener('click', () => {
    for (const key of Object.keys(active)) active[key].clear();
    for (const chip of chips) {
      chip.setAttribute('aria-pressed', 'false');
      chip.classList.remove('active');
    }
    apply();
  });

  apply();
</script>
