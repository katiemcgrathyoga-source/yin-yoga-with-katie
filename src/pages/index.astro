---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { derivedThumb, lenLabel, byRecencyThenWatch, videoHeadline } from '../lib/video';

// Recent classes lead (current thumbnails / branding), then older ones — each
// tier by watch-hours. New video files appear here automatically.
// Site rule: classes under 10 minutes are shorts/promos and don't belong here.
const videos = (await getCollection('videos'))
  .filter((v) => v.data.length_minutes >= 10)
  .sort((a, b) => byRecencyThenWatch(a.data, b.data));
type V = (typeof videos)[number];

// --- Length buckets ----------------------------------------------------------
const BUCKETS = [
  { key: 'under-20', label: 'Under 20 min', test: (m: number) => m < 20 },
  { key: '20-40', label: '20–40 min', test: (m: number) => m >= 20 && m < 40 },
  { key: '40-60', label: '40–60 min', test: (m: number) => m >= 40 && m < 60 },
  { key: '60-90', label: '60–90 min', test: (m: number) => m >= 60 },
];
const bucketOf = (m: number) => BUCKETS.find((b) => b.test(m))!.key;
const presentBuckets = BUCKETS.filter((b) => videos.some((v) => bucketOf(v.data.length_minutes) === b.key));

// Body-area buckets — used to build the merged Focus filter (below).
const AREA_BUCKETS = [
  { key: 'hips', label: 'Hips', match: (a: string) => /hip|groin/.test(a) },
  { key: 'lower-back', label: 'Lower back', match: (a: string) => /lower back|low back|sacrum/.test(a) },
  { key: 'shoulders', label: 'Neck & shoulders', match: (a: string) => /shoulder|neck|upper back|chest/.test(a) },
];
const areaKeys = (v: V) => {
  const set = new Set<string>();
  for (const raw of v.data.body_areas) {
    const a = raw.toLowerCase();
    for (const b of AREA_BUCKETS) if (b.match(a)) set.add(b.key);
  }
  if (v.data.intent_tags.includes('hips-lower-back')) { set.add('hips'); set.add('lower-back'); }
  return [...set];
};

// --- Focus: intent + body area merged into one filter row (per the design) ----
const FOCUS = [
  { key: 'sleep', label: 'Sleep', match: (v: V) => v.data.intent_tags.includes('sleep') },
  { key: 'calm', label: 'Stress & calm', match: (v: V) => v.data.intent_tags.some((t) => ['nervous-system', 'stress'].includes(t)) },
  { key: 'energy', label: 'Energy', match: (v: V) => v.data.intent_tags.includes('energy') },
  { key: 'flexibility', label: 'Flexibility', match: (v: V) => v.data.intent_tags.includes('flexibility') },
  { key: 'hips', label: 'Hips', match: (v: V) => areaKeys(v).includes('hips') },
  { key: 'lower-back', label: 'Lower back', match: (v: V) => areaKeys(v).includes('lower-back') },
  { key: 'shoulders', label: 'Neck & shoulders', match: (v: V) => areaKeys(v).includes('shoulders') },
  { key: 'full-body', label: 'Full body', match: (v: V) => v.data.intent_tags.includes('full-body') },
];
const focusKeys = (v: V) => FOCUS.filter((f) => f.match(v)).map((f) => f.key);
const focusLabels = (v: V) => FOCUS.filter((f) => f.match(v)).map((f) => f.label);
const presentFocus = FOCUS.filter((f) => videos.some((v) => f.match(v)));

// Signature filmstrip: a marquee of recent thumbnails (decorative, not links).
const stripVideos = videos.slice(0, 10);
const roughCount = Math.max(10, Math.floor(videos.length / 10) * 10);

const ogImage = new URL('/og/card.png', Astro.site);
ogImage.searchParams.set('t', 'Free Yin Yoga Classes');
ogImage.searchParams.set('s', 'Full-length practices to follow along');
---

<BaseLayout
  title="Yin Yoga with Katie — the video library"
  description="A growing library of full-length Yin Yoga classes you can follow on YouTube. Filter by focus and length to find the right practice for today."
  image={ogImage.href}
>
  <div class="wrap lib">
    <header class="hero lib-hero">
      <p class="eyebrow">Yin yoga with Katie</p>
      <h1>The Library</h1>
      <p class="lib-sub">Full-length classes to follow along on YouTube — filter for what your body needs today.</p>
    </header>

    <div class="lib-strip" aria-hidden="true">
      <div class="lib-strip-track">
        {[...stripVideos, ...stripVideos].map((v) => (
          <img src={derivedThumb(v.data, 'mqdefault')} alt="" loading="lazy" width="176" height="99" />
        ))}
      </div>
    </div>
    <p class="lib-strip-caption">{roughCount}+ free classes, 10 to 90 minutes</p>

    <section>
      <div class="filters lib-filters" id="filters">
        <div class="facet">
          <span class="facet-label">Focus</span>
          <div class="chips lib-chiprow">
            {presentFocus.map((f) => (
              <button type="button" class="chip" data-facet="focus" data-value={f.key} aria-pressed="false">{f.label}</button>
            ))}
          </div>
        </div>

        {presentBuckets.length > 0 && (
          <div class="facet">
            <span class="facet-label">Length</span>
            <div class="chips lib-chiprow">
              {presentBuckets.map((b) => (
                <button type="button" class="chip" data-facet="length" data-value={b.key} aria-pressed="false">{b.label}</button>
              ))}
            </div>
          </div>
        )}

        <div class="filter-meta">
          <button type="button" class="chip chip-clear" id="clear-filters" hidden>Clear filters</button>
          <span class="count" id="result-count" aria-live="polite"></span>
        </div>
      </div>

      <div class="tiles lib-grid" id="tiles">
        {videos.map((v) => (
          <a
            class="tile"
            href={`/videos/${v.data.slug}`}
            data-tile
            data-focus={focusKeys(v).join('|')}
            data-length={bucketOf(v.data.length_minutes)}
          >
            <div class="tile-thumb">
              <img class="tile-img" src={derivedThumb(v.data)} alt={v.data.title} loading="lazy" width="480" height="270" />
              <span class="tile-len">{lenLabel(v.data)}</span>
              {v.data.membership && <span class="tile-members">Members</span>}
            </div>
            <div class="tile-body">
              <h3 class="tile-name">{videoHeadline(v.data)}</h3>
              {focusLabels(v).length > 0 && (
                <p class="tile-meta">{focusLabels(v).slice(0, 2).join(' · ')}</p>
              )}
            </div>
          </a>
        ))}
      </div>

      <p class="empty" id="empty" hidden>No classes match those filters yet.</p>
      <div class="show-more">
        <button type="button" class="btn btn-secondary" id="show-all" hidden></button>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Client-side faceted filtering — no framework. OR within a facet, AND across.
  const tiles = Array.from(document.querySelectorAll<HTMLElement>('[data-tile]'));
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip[data-facet]'));
  const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement | null;
  const countEl = document.getElementById('result-count');
  const emptyEl = document.getElementById('empty');

  const showAllBtn = document.getElementById('show-all') as HTMLButtonElement | null;
  const LIMIT = 36;
  let showAll = false;

  const active: Record<string, Set<string>> = { focus: new Set(), length: new Set() };
  const split = (v: string | undefined) => (v ? v.split('|').filter(Boolean) : []);

  function apply() {
    const anyActive = active.focus.size + active.length.size > 0;
    const capped = !anyActive && !showAll;
    let matched = 0;
    let shown = 0;
    for (const tile of tiles) {
      const focus = split(tile.dataset.focus);
      const length = tile.dataset.length ?? '';
      const okFocus = active.focus.size === 0 || focus.some((v) => active.focus.has(v));
      const okLength = active.length.size === 0 || active.length.has(length);
      const match = okFocus && okLength;
      if (match) matched++;
      const show = match && (!capped || shown < LIMIT);
      tile.hidden = !show;
      if (show) shown++;
    }
    if (clearBtn) clearBtn.hidden = !anyActive;
    if (emptyEl) emptyEl.hidden = matched > 0;
    if (countEl) countEl.textContent = anyActive ? `${matched} of ${tiles.length} ${tiles.length === 1 ? 'class' : 'classes'}` : '';
    if (showAllBtn) {
      const hiddenCount = tiles.length - LIMIT;
      showAllBtn.hidden = !(capped && hiddenCount > 0);
      showAllBtn.textContent = `Show all ${tiles.length} classes`;
    }
  }

  showAllBtn?.addEventListener('click', () => { showAll = true; apply(); });

  for (const chip of chips) {
    chip.addEventListener('click', () => {
      const facet = chip.dataset.facet!, value = chip.dataset.value!, set = active[facet];
      if (set.has(value)) { set.delete(value); chip.setAttribute('aria-pressed', 'false'); chip.classList.remove('active'); }
      else { set.add(value); chip.setAttribute('aria-pressed', 'true'); chip.classList.add('active'); }
      apply();
    });
  }

  clearBtn?.addEventListener('click', () => {
    for (const key of Object.keys(active)) active[key].clear();
    for (const chip of chips) { chip.setAttribute('aria-pressed', 'false'); chip.classList.remove('active'); }
    apply();
  });

  apply();
</script>
