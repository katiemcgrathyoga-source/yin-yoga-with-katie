---
/**
 * RoutinePlayer — a focused, follow-along practice player.
 *
 * On "Begin", it expands to a distraction-free full-screen mode: a 15-second
 * lead-in to get into the first pose, then each hold timed with a gentle chime
 * and a calm "ease out → next pose" hand-off. You can nudge any hold ±30s on the
 * fly, and at the end it generates a branded, shareable completion badge.
 *
 * The custom element is framework-free and exposes setSequence()/beginPractice()
 * so the custom routine builder can drive it with a sequence built in the browser.
 */
interface Hold { name: string; slug: string; img: string; seconds: number; note?: string; sideLabel?: string; }
interface Props { title: string; holds: Hold[]; shareUrl?: string; imageUrl?: string; }
const { title, holds, shareUrl, imageUrl } = Astro.props;
---

<routine-player data-title={title} data-share-url={shareUrl ?? ''} data-image={imageUrl ?? ''}>
  <script type="application/json" class="rp-data" is:inline set:html={JSON.stringify(holds)} />
</routine-player>

<script>
  interface Hold { name: string; slug: string; img: string; seconds: number; note?: string; sideLabel?: string; }

  const PREP = 15;        // lead-in seconds to get into the first pose
  const TRANSITION = 15;  // ease-out seconds between poses
  const RING_C = 326.726; // circumference of an r=52 circle
  const SITE = 'yinyogawithkatie.com';

  // Inline brand glyphs (Simple Icons paths) so no external requests are needed.
  const ICON: Record<string, string> = {
    native: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>`,
    facebook: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
    x: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>`,
    pinterest: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.2-2.405.041-3.441.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 12.018.026L12.017 0z"/></svg>`,
    whatsapp: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24.044 12.045.044 5.463.044.104 5.404.101 11.987c0 2.096.549 4.142 1.595 5.945L0 24l6.335-1.652a11.899 11.899 0 005.71 1.454h.006c6.585 0 11.946-5.36 11.949-11.945a11.821 11.821 0 00-3.495-8.404"/></svg>`,
    email: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/></svg>`,
  };

  const loadImg = (src: string) =>
    new Promise<HTMLImageElement>((res, rej) => {
      const i = new Image();
      i.onload = () => res(i);
      i.onerror = rej;
      i.src = src;
    });

  class RoutinePlayer extends HTMLElement {
    holds: Hold[] = [];
    idx = 0;
    phase: 'ready' | 'prep' | 'holding' | 'transition' | 'done' = 'ready';
    paused = false;
    remaining = 0;
    endAt = 0;
    raf: number | undefined;
    audio: AudioContext | null = null;
    wakeLock: any = null;
    onEsc = (e: KeyboardEvent) => { if (e.key === 'Escape') this.exitFocus(); };

    connectedCallback() {
      try { this.holds = JSON.parse(this.querySelector('.rp-data')?.textContent || '[]'); } catch { this.holds = []; }
      if (!this.holds.length) return;
      this.build();
    }
    disconnectedCallback() { this.stopTick(); this.releaseWake(); this.unlockScroll(); }

    photo!: HTMLImageElement; count!: HTMLElement; nameEl!: HTMLElement; note!: HTMLElement;
    clock!: HTMLElement; prog!: SVGCircleElement; toggle!: HTMLButtonElement; nextup!: HTMLElement;
    live!: HTMLElement; badge!: HTMLCanvasElement; dots: HTMLElement[] = [];

    build() {
      this.innerHTML = `
        <div class="rp">
          <div class="rp-bar">
            <span class="rp-routine">${this.dataset.title || 'Your practice'}</span>
            <button type="button" class="rp-exit" aria-label="End practice">✕&nbsp;End</button>
          </div>
          <div class="rp-stage">
            <img class="rp-photo" alt="" />
            <div class="rp-overlay">
              <p class="rp-count"></p>
              <h3 class="rp-name"></h3>
              <p class="rp-note"></p>
            </div>
            <div class="rp-ring-wrap">
              <svg class="rp-ring" viewBox="0 0 120 120" aria-hidden="true">
                <circle class="rp-track" cx="60" cy="60" r="52"></circle>
                <circle class="rp-prog" cx="60" cy="60" r="52" stroke-dasharray="${RING_C}" stroke-dashoffset="0"></circle>
              </svg>
              <span class="rp-clock">0:00</span>
            </div>
            <p class="rp-nextup"></p>
          </div>
          <div class="rp-adjust">
            <button type="button" class="rp-minus" aria-label="Take 30 seconds off this hold">−30s</button>
            <span class="rp-adjust-label">adjust hold</span>
            <button type="button" class="rp-plus" aria-label="Add 30 seconds to this hold">+30s</button>
          </div>
          <div class="rp-controls">
            <button type="button" class="rp-prev" aria-label="Previous pose">‹ Prev</button>
            <button type="button" class="rp-toggle btn-cta">Begin practice</button>
            <button type="button" class="rp-next" aria-label="Next pose">Skip ›</button>
          </div>
          <div class="rp-dots" aria-hidden="true"></div>
          <div class="rp-done">
            <canvas class="rp-badge" width="1080" height="1080"></canvas>
            <p class="rp-share-label">Share your practice</p>
            <div class="rp-socials">
              <button type="button" class="rp-soc rp-soc-native" aria-label="Share with the badge image" title="Share…">${ICON.native}</button>
              <button type="button" class="rp-soc" data-net="facebook" aria-label="Share on Facebook" title="Facebook">${ICON.facebook}</button>
              <button type="button" class="rp-soc" data-net="x" aria-label="Share on X" title="X">${ICON.x}</button>
              <button type="button" class="rp-soc" data-net="pinterest" aria-label="Share on Pinterest" title="Pinterest">${ICON.pinterest}</button>
              <button type="button" class="rp-soc" data-net="whatsapp" aria-label="Share on WhatsApp" title="WhatsApp">${ICON.whatsapp}</button>
              <button type="button" class="rp-soc" data-net="email" aria-label="Share by email" title="Email">${ICON.email}</button>
            </div>
            <div class="rp-done-actions">
              <button type="button" class="rp-download">Download badge</button>
              <button type="button" class="rp-again">Practise again</button>
            </div>
          </div>
          <p class="rp-live" aria-live="polite"></p>
        </div>`;

      const $ = (s: string) => this.querySelector(s) as any;
      this.photo = $('.rp-photo'); this.count = $('.rp-count'); this.nameEl = $('.rp-name');
      this.note = $('.rp-note'); this.clock = $('.rp-clock'); this.prog = $('.rp-prog');
      this.toggle = $('.rp-toggle'); this.nextup = $('.rp-nextup'); this.live = $('.rp-live');
      this.badge = $('.rp-badge');

      this.toggle.addEventListener('click', () => this.onToggle());
      $('.rp-next').addEventListener('click', () => this.skip());
      $('.rp-prev').addEventListener('click', () => this.prev());
      $('.rp-exit').addEventListener('click', () => this.exitFocus());
      $('.rp-minus').addEventListener('click', () => this.adjust(-30));
      $('.rp-plus').addEventListener('click', () => this.adjust(30));
      $('.rp-soc-native').addEventListener('click', () => this.shareBadge());
      this.querySelectorAll<HTMLButtonElement>('.rp-soc[data-net]').forEach((b) =>
        b.addEventListener('click', () => this.openSocial(b.dataset.net!)),
      );
      $('.rp-download').addEventListener('click', () => this.downloadBadge());
      $('.rp-again').addEventListener('click', () => this.restart());

      const dotWrap = $('.rp-dots');
      dotWrap.innerHTML = this.holds.map(() => `<span class="rp-dot"></span>`).join('');
      this.dots = [...this.querySelectorAll<HTMLElement>('.rp-dot')];

      this.idx = 0; this.phase = 'ready';
      this.showHold(0, false);
    }

    /** Public: load a new sequence (used by the custom builder). */
    setSequence(title: string, holds: Hold[], shareUrl = '') {
      this.stopTick();
      this.dataset.title = title;
      this.dataset.shareUrl = shareUrl;
      this.holds = holds;
      this.build();
    }

    fmt(s: number) { s = Math.max(0, Math.round(s)); return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`; }

    setPhaseClass() {
      this.classList.toggle('is-prep', this.phase === 'prep');
      this.classList.toggle('is-holding', this.phase === 'holding');
      this.classList.toggle('is-transition', this.phase === 'transition');
      this.classList.toggle('is-done', this.phase === 'done');
    }

    showHold(i: number, running: boolean) {
      const h = this.holds[i];
      this.photo.src = h.img; this.photo.alt = `${h.name} yin yoga pose`;
      this.count.textContent = `Pose ${i + 1} of ${this.holds.length}${h.sideLabel ? ' · ' + h.sideLabel : ''}`;
      this.nameEl.textContent = h.name;
      this.note.textContent = h.note || '';
      this.remaining = h.seconds;
      this.renderClock(h.seconds, h.seconds);
      this.dots.forEach((d, k) => { d.classList.toggle('is-done', k < i); d.classList.toggle('is-current', k === i); });
      this.updateNextUp(i);
      if (!running) this.toggle.textContent = i === 0 ? 'Begin practice' : 'Resume';
    }

    updateNextUp(i: number) {
      const n = this.holds[i + 1];
      this.nextup.textContent = n ? `Next up · ${n.name}${n.sideLabel ? ' · ' + n.sideLabel : ''}` : 'Last pose';
    }

    renderClock(remaining: number, total: number) {
      this.clock.textContent = this.fmt(remaining);
      const frac = total > 0 ? Math.max(0, Math.min(1, remaining / total)) : 0;
      this.prog.style.strokeDashoffset = String(RING_C * (1 - frac));
    }

    onToggle() {
      if (this.phase === 'ready') this.beginPractice();
      else if (this.phase === 'done') this.restart();
      else this.paused ? this.resume() : this.pause();
    }

    /** Public: enter focus mode and start the lead-in. */
    beginPractice() {
      this.enterFocus();
      this.ensureAudio();
      this.requestWake();
      this.idx = 0;
      this.startPrep();
    }

    startPrep() {
      this.phase = 'prep'; this.paused = false; this.setPhaseClass();
      const h = this.holds[this.idx];
      this.photo.src = h.img; this.photo.alt = '';
      this.count.textContent = 'Get ready';
      this.nameEl.textContent = h.name;
      this.note.textContent = 'Settle into the pose — the timer starts in a moment.';
      this.updateNextUp(this.idx);
      this.toggle.textContent = 'Pause';
      this.live.textContent = `Get into ${h.name}. Starting soon.`;
      this.runCountdown(PREP, PREP, () => this.startHold(this.idx));
    }

    startHold(i: number) {
      this.idx = i; this.phase = 'holding'; this.paused = false; this.setPhaseClass();
      this.showHold(i, true);
      this.toggle.textContent = 'Pause';
      this.live.textContent = `${this.holds[i].name}, ${this.fmt(this.holds[i].seconds)}.`;
      this.runCountdown(this.holds[i].seconds, this.holds[i].seconds, () => this.onHoldDone());
    }

    onHoldDone() {
      this.chime();
      if (this.idx >= this.holds.length - 1) { this.finish(); return; }
      this.startTransition();
    }

    startTransition() {
      this.phase = 'transition'; this.paused = false; this.setPhaseClass();
      const cur = this.holds[this.idx];
      const next = this.holds[this.idx + 1];
      const switching = next.name === cur.name;
      this.count.textContent = 'Ease out slowly';
      this.nameEl.textContent = switching ? 'Switch sides' : 'Next pose';
      this.note.textContent = `${next.name}${next.sideLabel ? ' · ' + next.sideLabel : ''}`;
      this.updateNextUp(this.idx);
      this.toggle.textContent = 'Pause';
      this.live.textContent = switching ? 'Switch sides.' : `Next, ${next.name}.`;
      this.runCountdown(TRANSITION, TRANSITION, () => this.advance());
    }

    advance() { this.startHold(this.idx + 1); }

    skip() {
      if (this.phase === 'ready' || this.phase === 'done') return;
      this.stopTick();
      if (this.phase === 'prep') { this.startHold(this.idx); return; }
      if (this.idx >= this.holds.length - 1) { this.finish(); return; }
      this.advance();
    }

    prev() {
      if (this.phase === 'ready' || this.phase === 'done') return;
      this.stopTick();
      if (this.phase !== 'transition') this.idx = Math.max(0, this.idx - 1);
      this.startHold(this.idx);
    }

    pause() {
      this.stopTick(); this.paused = true;
      this.toggle.textContent = 'Resume';
      this.live.textContent = 'Paused.';
    }
    resume() {
      this.paused = false; this.toggle.textContent = 'Pause';
      const total =
        this.phase === 'prep' ? PREP : this.phase === 'transition' ? TRANSITION : this.holds[this.idx].seconds;
      const done =
        this.phase === 'prep' ? () => this.startHold(this.idx)
        : this.phase === 'transition' ? () => this.advance()
        : () => this.onHoldDone();
      this.runCountdown(this.remaining, total, done);
    }

    /** Nudge the relevant hold ±30s. Applies live when holding. */
    adjust(delta: number) {
      if (this.phase === 'done' || this.phase === 'ready') return;
      const target = this.phase === 'transition' ? this.idx + 1 : this.idx;
      const h = this.holds[target];
      if (!h) return;
      h.seconds = Math.max(5, h.seconds + delta);
      if (this.phase === 'holding' && !this.paused) {
        this.remaining = Math.max(1, this.remaining + delta);
        this.runCountdown(this.remaining, h.seconds, () => this.onHoldDone());
      } else if (this.phase === 'holding') {
        this.remaining = Math.max(1, this.remaining + delta);
        this.renderClock(this.remaining, h.seconds);
      }
      this.live.textContent = `Hold set to ${this.fmt(h.seconds)}.`;
    }

    async finish() {
      this.stopTick(); this.releaseWake();
      this.phase = 'done'; this.setPhaseClass();
      this.count.textContent = 'Practice complete';
      this.nameEl.textContent = 'Beautifully done';
      this.note.textContent = 'Rest as long as you like, then roll to one side and come up slowly.';
      this.clock.textContent = '✓';
      this.prog.style.strokeDashoffset = '0';
      this.dots.forEach((d) => { d.classList.add('is-done'); d.classList.remove('is-current'); });
      this.live.textContent = 'Practice complete. Rest as long as you like.';
      await this.drawBadge();
    }

    restart() { this.idx = 0; this.enterFocus(); this.ensureAudio(); this.requestWake(); this.startPrep(); }

    // --- focus mode -----------------------------------------------------------
    enterFocus() {
      this.classList.add('is-focus');
      this.lockScroll();
      document.addEventListener('keydown', this.onEsc);
    }
    exitFocus() {
      this.stopTick(); this.releaseWake();
      this.classList.remove('is-focus');
      this.unlockScroll();
      document.removeEventListener('keydown', this.onEsc);
      this.phase = 'ready'; this.setPhaseClass();
      this.idx = 0; this.showHold(0, false);
    }
    lockScroll() { document.documentElement.style.overflow = 'hidden'; }
    unlockScroll() { document.documentElement.style.overflow = ''; }

    // --- countdown ------------------------------------------------------------
    runCountdown(from: number, total: number, onDone: () => void) {
      this.stopTick();
      this.remaining = from;
      this.endAt = performance.now() + from * 1000;
      const step = () => {
        this.remaining = (this.endAt - performance.now()) / 1000;
        if (this.remaining <= 0) { this.remaining = 0; this.renderClock(0, total); this.stopTick(); onDone(); return; }
        this.renderClock(this.remaining, total);
        this.raf = window.setTimeout(step, 200);
      };
      step();
    }
    stopTick() { if (this.raf) { clearTimeout(this.raf); this.raf = undefined; } }

    // --- gentle bell + wake lock ---------------------------------------------
    ensureAudio() {
      try {
        if (!this.audio) this.audio = new (window.AudioContext || (window as any).webkitAudioContext)();
        if (this.audio.state === 'suspended') this.audio.resume();
      } catch {}
    }
    chime() {
      const ctx = this.audio; if (!ctx) return;
      const now = ctx.currentTime;
      ([[880, 0], [587.33, 0.5]] as [number, number][]).forEach(([freq, at]) => {
        const o = ctx.createOscillator(), g = ctx.createGain();
        o.type = 'sine'; o.frequency.value = freq;
        g.gain.setValueAtTime(0.0001, now + at);
        g.gain.exponentialRampToValueAtTime(0.22, now + at + 0.04);
        g.gain.exponentialRampToValueAtTime(0.0001, now + at + 1.6);
        o.connect(g).connect(ctx.destination);
        o.start(now + at); o.stop(now + at + 1.7);
      });
    }
    async requestWake() { try { if ('wakeLock' in navigator) this.wakeLock = await (navigator as any).wakeLock.request('screen'); } catch {} }
    releaseWake() { try { this.wakeLock?.release?.(); } catch {} this.wakeLock = null; }

    // --- shareable completion badge ------------------------------------------
    async drawBadge() {
      const c = this.badge, ctx = c.getContext('2d');
      if (!ctx) return;
      const W = 1080, H = 1080;
      try { await (document as any).fonts?.ready; } catch {}
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = '#F9F1EA'; ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = '#89494B'; ctx.lineWidth = 5; ctx.strokeRect(46, 46, W - 92, H - 92);
      ctx.textAlign = 'center';

      try {
        const img = await loadImg('/brand/submark-deep-sage.png');
        const iw = 190, ih = img.height * (iw / img.width);
        ctx.drawImage(img, (W - iw) / 2, 150, iw, ih);
      } catch {}

      ctx.fillStyle = '#6E756F';
      ctx.font = "600 30px Cabin, system-ui, sans-serif";
      (ctx as any).letterSpacing = '6px';
      ctx.fillText('I  COMPLETED', W / 2, 470);
      (ctx as any).letterSpacing = '0px';

      ctx.fillStyle = '#48544C';
      ctx.font = '600 74px "Noto Serif TC", Georgia, serif';
      const wrapY = this.wrapText(ctx, this.dataset.title || 'my Yin practice', W / 2, 560, W - 240, 86);

      ctx.strokeStyle = '#89494B'; ctx.lineWidth = 3;
      ctx.beginPath(); ctx.moveTo(W / 2 - 60, wrapY + 40); ctx.lineTo(W / 2 + 60, wrapY + 40); ctx.stroke();

      ctx.fillStyle = '#48544C';
      ctx.font = 'italic 42px "Noto Serif TC", Georgia, serif';
      ctx.fillText('Yin Yoga with Katie', W / 2, wrapY + 130);
      ctx.fillStyle = '#6E756F';
      ctx.font = '500 30px Cabin, system-ui, sans-serif';
      ctx.fillText(SITE, W / 2, wrapY + 180);
    }

    wrapText(ctx: CanvasRenderingContext2D, text: string, x: number, y: number, maxW: number, lh: number) {
      const words = text.split(' ');
      const lines: string[] = [];
      let line = '';
      for (const w of words) {
        const test = line ? line + ' ' + w : w;
        if (ctx.measureText(test).width > maxW && line) { lines.push(line); line = w; } else line = test;
      }
      if (line) lines.push(line);
      lines.forEach((l, i) => ctx.fillText(l, x, y + i * lh));
      return y + (lines.length - 1) * lh;
    }

    badgeText() {
      return `I completed the ${this.dataset.title} routine on ${SITE} 🧘`;
    }

    /** Open a platform share dialog. Shares the routine LINK + caption (the post
     *  preview uses the page's own image); the badge PNG goes via Share…/Download. */
    openSocial(net: string) {
      const url = this.dataset.shareUrl || `https://${SITE}`;
      const text = this.badgeText();
      const img = this.dataset.image || '';
      const e = encodeURIComponent;
      let href = '';
      switch (net) {
        case 'facebook': href = `https://www.facebook.com/sharer/sharer.php?u=${e(url)}`; break;
        case 'x': href = `https://x.com/intent/tweet?text=${e(text)}&url=${e(url)}`; break;
        case 'pinterest': href = `https://www.pinterest.com/pin/create/button/?url=${e(url)}&description=${e(text)}${img ? `&media=${e(img)}` : ''}`; break;
        case 'whatsapp': href = `https://wa.me/?text=${e(text + ' ' + url)}`; break;
        case 'email': window.location.href = `mailto:?subject=${e('My Yin practice')}&body=${e(text + '\n\n' + url)}`; return;
        default: return;
      }
      window.open(href, '_blank', 'noopener,noreferrer,width=600,height=640');
    }
    async shareBadge() {
      const url = this.dataset.shareUrl || `https://${SITE}`;
      const text = this.badgeText();
      const blob: Blob | null = await new Promise((r) => this.badge.toBlob(r, 'image/png'));
      if (blob && (navigator as any).canShare) {
        const file = new File([blob], 'yin-practice.png', { type: 'image/png' });
        if ((navigator as any).canShare({ files: [file] })) {
          try { await (navigator as any).share({ files: [file], text, url }); return; } catch {}
        }
      }
      if (navigator.share) { try { await navigator.share({ title: 'Yin Yoga with Katie', text, url }); return; } catch {} }
      this.downloadBadge();
    }
    downloadBadge() {
      this.badge.toBlob((blob) => {
        if (!blob) return;
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'yin-practice.png';
        a.click();
        setTimeout(() => URL.revokeObjectURL(a.href), 1000);
      }, 'image/png');
    }
  }

  if (!customElements.get('routine-player')) customElements.define('routine-player', RoutinePlayer);
</script>
