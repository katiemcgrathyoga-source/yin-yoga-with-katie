---
/**
 * The site-wide call to action — a single, low-friction ask: the free two-hour
 * Yin retreat (email capture). Calm, no hype — in Katie's voice.
 */
interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
}
const {
  eyebrow = 'A little gift',
  heading = 'A free two-hour retreat, on me',
  body = "Give yourself two hours of pure rest — a guided Yin, restorative and Yoga Nidra journey to calm your nervous system and melt off a stressful week. Pop in your email and it's yours to keep.",
} = Astro.props;
---

<div class="membership cta-block">
  <p class="eyebrow">{eyebrow}</p>
  <h2>{heading}</h2>
  <p>{body}</p>
  <div class="cta-actions">
    <a class="btn-cta" href="/free-class">Send me the free retreat →</a>
  </div>
</div>
