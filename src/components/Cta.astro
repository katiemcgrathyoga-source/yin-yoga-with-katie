---
import { SITE } from '../data/site';

/**
 * The site-wide two-tier call to action. Primary = the paid YouTube membership
 * (the revenue driver); secondary = the free on-site Programs (low-friction,
 * keeps people practising). Calm, no hype — in Katie's voice.
 */
interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
}
const {
  eyebrow = 'Practise with me',
  heading = 'A gentle place to start',
  body = 'New here? Take a free members-only class — my gift — then follow my monthly calendar so you always know what to practise next.',
} = Astro.props;
---

<div class="membership cta-block">
  <p class="eyebrow">{eyebrow}</p>
  <h2>{heading}</h2>
  <p>{body}</p>
  <div class="cta-actions">
    <a class="btn-cta" href="/free-class">Get a free class</a>
    <a class="cta-secondary" href="/calendar">Follow my monthly calendar →</a>
  </div>
  <p class="cta-tertiary">Ready for more? <a href={SITE.membershipUrl} target="_blank" rel="noopener">Join the membership →</a></p>
</div>
