---
/**
 * The site-wide call to action — a single, low-friction ask: the free two-hour
 * Yin retreat (email capture). Calm, no hype — in Katie's voice.
 */
interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
}
const {
  eyebrow = 'A gift from me',
  heading = 'Two hours to completely switch off',
  body = 'Treat yourself to my free two-hour Yin, restorative and Yoga Nidra retreat. Free, and yours to keep.',
} = Astro.props;
---

<div class="membership cta-block">
  <p class="eyebrow">{eyebrow}</p>
  <h2>{heading}</h2>
  <p class="cta-members">✦ A members-only class — free for you</p>
  <p>{body}</p>
  <div class="cta-actions">
    <a class="btn-cta" href="/free-class">Send me the free retreat →</a>
  </div>
</div>
