---
interface Props {
  active: 'week' | 'month' | 'build';
}
const { active } = Astro.props;
const tabs = [
  { key: 'week', label: 'This Week', href: '/calendar' },
  { key: 'month', label: 'This Month', href: '/calendar/month' },
  { key: 'build', label: 'Build Your Own', href: '/calendar/build' },
];
---

<nav class="cal-nav" aria-label="Calendar views">
  {
    tabs.map((t) => (
      <a href={t.href} class:list={['cal-tab', { active: t.key === active }]} aria-current={t.key === active ? 'page' : undefined}>
        {t.label}
      </a>
    ))
  }
</nav>
